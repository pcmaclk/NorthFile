<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="NorthFileUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NorthFileUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Resources/AppThemeResources.xaml" />
                <ResourceDictionary Source="Resources/EntryItemHostResources.xaml" />
                <ResourceDictionary Source="Resources/MenuFlyoutResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <local:LocalizedStrings x:Key="Strings" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
