<UserControl
    x:Class="NorthFileUI.Controls.ModalActionDialog"
    x:Name="RootControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="OverlayRoot" Background="{ThemeResource ContentDialogSmokeFill}">
        <Border
            x:Name="DialogHost"
            Width="{ThemeResource ContentDialogMaxWidth}"
            MinWidth="{ThemeResource ContentDialogMinWidth}"
            MinHeight="{ThemeResource ContentDialogMinHeight}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource ContentDialogBackground}"
            BorderBrush="{ThemeResource ContentDialogBorderBrush}"
            BorderThickness="{ThemeResource ContentDialogBorderWidth}"
            CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="ContentSurface"
                    Background="{ThemeResource ContentDialogTopOverlay}"
                    BorderBrush="{ThemeResource ContentDialogSeparatorBorderBrush}"
                    BorderThickness="{ThemeResource ContentDialogSeparatorThickness}">
                    <StackPanel Padding="{ThemeResource ContentDialogPadding}" Spacing="0">
                        <TextBlock
                            x:Name="TitleTextBlock"
                            Margin="{ThemeResource ContentDialogTitleMargin}"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="{x:Bind Title, Mode=OneWay}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="MessageTextBlock"
                            Text="{x:Bind Message, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border
                    x:Name="FooterSurface"
                    Grid.Row="1"
                    Background="{ThemeResource ContentDialogBackground}"
                    Padding="{ThemeResource ContentDialogPadding}">
                    <StackPanel Spacing="8">
                        <Button
                            x:Name="PrimaryButton"
                            Height="36"
                            HorizontalAlignment="Stretch"
                            Content="{x:Bind PrimaryText, Mode=OneWay}"
                            Style="{ThemeResource AccentButtonStyle}"
                            UseSystemFocusVisuals="False"
                            Click="PrimaryButton_Click" />
                        <Button
                            x:Name="TertiaryButton"
                            Height="36"
                            HorizontalAlignment="Stretch"
                            Visibility="{x:Bind TertiaryButtonVisibility, Mode=OneWay}"
                            Content="{x:Bind TertiaryText, Mode=OneWay}"
                            UseSystemFocusVisuals="False"
                            Click="TertiaryButton_Click" />
                        <Button
                            x:Name="SecondaryButton"
                            Height="36"
                            HorizontalAlignment="Stretch"
                            Visibility="{x:Bind SecondaryButtonVisibility, Mode=OneWay}"
                            Content="{x:Bind SecondaryText, Mode=OneWay}"
                            UseSystemFocusVisuals="False"
                            Click="SecondaryButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
