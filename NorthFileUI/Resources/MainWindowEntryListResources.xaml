<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NorthFileUI.Controls">
    <Style x:Key="EntryListScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="IsTabStop" Value="True" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="DetailsEntryItemHostStyle" TargetType="controls:EntryItemHost" BasedOn="{StaticResource DefaultEntryItemHostStyle}">
        <Setter Property="Margin" Value="0,2,0,2" />
        <Setter Property="Padding" Value="0,3,0,3" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="IndicatorBrush" Value="{ThemeResource TreeViewItemSelectionIndicatorForeground}" />
        <Setter Property="AnchorBorderBrush" Value="{ThemeResource TreeViewItemSelectionIndicatorForeground}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="GroupedEntryItemHostStyle" TargetType="controls:EntryItemHost" BasedOn="{StaticResource DetailsEntryItemHostStyle}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="DetailsCellTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
</ResourceDictionary>
