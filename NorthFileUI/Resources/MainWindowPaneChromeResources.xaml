<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PaneAddressBreadcrumbBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="12,0,12,0" />
        <Setter Property="Background" Value="{ThemeResource InactivePaneInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AddressSearchChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
    </Style>

    <Style x:Key="PaneAddressTextBoxStyle" TargetType="TextBox">
        <Setter Property="Padding" Value="12,6,36,0" />
        <Setter Property="Background" Value="{ThemeResource InactivePaneInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AddressSearchChromeBorderBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource InactivePaneForegroundBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="PaneSearchTextBoxStyle" TargetType="TextBox">
        <Setter Property="Padding" Value="12,5,12,4" />
        <Setter Property="Background" Value="{ThemeResource InactivePaneInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AddressSearchChromeBorderBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource InactivePaneForegroundBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="PaneBreadcrumbButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="6,0,6,0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="PaneBreadcrumbChevronButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="4,0,4,0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="PaneOverflowBreadcrumbButtonStyle" TargetType="Button" BasedOn="{StaticResource PaneBreadcrumbChevronButtonStyle}">
        <Setter Property="Margin" Value="0,0,4,0" />
    </Style>
</ResourceDictionary>
