<UserControl
    x:Class="FileExplorerUI.Controls.EntryNameCell"
    x:Name="RootControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" VerticalAlignment="Center">
        <Grid.RenderTransform>
            <TranslateTransform Y="0" />
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="IconColumnDefinition" />
            <ColumnDefinition x:Name="IconSpacingColumnDefinition" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock
            x:Name="IconTextBlock"
            Grid.Column="0"
            VerticalAlignment="Center"
            FontFamily="Segoe Fluent Icons"
            />

        <TextBlock
            x:Name="EntryNameTextBlock"
            Grid.Column="2"
            VerticalAlignment="Center"
            TextTrimming="CharacterEllipsis" />
    </Grid>
</UserControl>
