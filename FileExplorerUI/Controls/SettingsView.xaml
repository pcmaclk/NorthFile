<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FileExplorerUI.Controls.SettingsView"
    x:Name="RootControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Thickness x:Key="SettingsCardPadding">16,16,16,16</Thickness>
        <x:Double x:Key="SettingsCardMinWidth">148</x:Double>
        <x:Double x:Key="SettingsCardMinHeight">68</x:Double>
        <x:Double x:Key="SettingsCardItemHeaderFontSize">14</x:Double>
        <x:Double x:Key="SettingsCardItemDescriptionFontSize">12</x:Double>
        <x:Double x:Key="SettingsCardHeaderIconMaxSize">20</x:Double>
        <x:Double x:Key="SettingsCardContentMinWidth">120</x:Double>
        <Thickness x:Key="SettingsCardHeaderIconMargin">2,0,20,0</Thickness>

        <Style x:Key="SettingsSectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
            <Setter Property="Margin" Value="1,28,0,6" />
        </Style>

        <Style x:Key="SettingsSectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>

        <Style x:Key="SettingsItemCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
            <Setter Property="Padding" Value="{StaticResource SettingsCardPadding}" />
            <Setter Property="MinWidth" Value="{StaticResource SettingsCardMinWidth}" />
            <Setter Property="MinHeight" Value="{StaticResource SettingsCardMinHeight}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="SettingsItemHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource SettingsCardItemHeaderFontSize}" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <Style x:Key="SettingsItemDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Opacity" Value="0.72" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
            <Setter Property="FontSize" Value="{StaticResource SettingsCardItemDescriptionFontSize}" />
        </Style>

        <Style x:Key="SettingsIconHostStyle" TargetType="Border">
            <Setter Property="Width" Value="{StaticResource SettingsCardHeaderIconMaxSize}" />
            <Setter Property="Height" Value="{StaticResource SettingsCardHeaderIconMaxSize}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="{StaticResource SettingsCardHeaderIconMargin}" />
        </Style>

        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="{StaticResource SettingsCardContentMinWidth}" />
            <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
        </Style>

        <Style x:Key="SettingsToggleSwitchStyle" TargetType="ToggleSwitch" BasedOn="{StaticResource DefaultToggleSwitchStyle}">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="OnContent" Value="" />
            <Setter Property="OffContent" Value="" />
        </Style>

        <Style x:Key="SettingsActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="{StaticResource SettingsCardContentMinWidth}" />
        </Style>

        <Style x:Key="SettingsItemTextHostStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,24,0" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer
        x:Name="RootScrollViewer"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Auto"
        ViewChanged="RootScrollViewer_ViewChanged">
        <Grid Margin="36,24,36,36">
        <StackPanel
            x:Name="SettingsSectionsHost"
            MaxWidth="960"
            HorizontalAlignment="Stretch"
            Spacing="{StaticResource SettingsCardSpacing}">

            <TextBlock
                AutomationProperties.HeadingLevel="Level1"
                FontSize="34"
                FontWeight="SemiBold"
                Text="{Binding Source={StaticResource Strings}, Path=[SettingsPageTitle]}" />

            <StackPanel x:Name="GeneralSection" Spacing="{StaticResource SettingsCardSpacing}">
                <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionGeneral]}" />
                <TextBlock Style="{StaticResource SettingsSectionDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionGeneralDescription]}" />

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE8D7;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsLanguageTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsLanguageDescription]}" />
                        </StackPanel>
                        <ComboBox
                            x:Name="LanguagePreferenceComboBox"
                            Grid.Column="2"
                            Style="{StaticResource SettingsComboBoxStyle}"
                            SelectedIndex="0"
                            SelectionChanged="LanguagePreferenceComboBox_SelectionChanged">
                            <ComboBoxItem x:Name="LanguageUseSystemComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[SettingsUseSystem]}" />
                            <ComboBoxItem x:Name="LanguageChineseSimplifiedComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[SettingsLanguageChineseSimplified]}" />
                            <ComboBoxItem x:Name="LanguageEnglishComboBoxItem" Content="English" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <StackPanel Spacing="0">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                            <Border Style="{StaticResource SettingsIconHostStyle}">
                                <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE823;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                                <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsStartupTitle]}" />
                                <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsStartupDescription]}" />
                            </StackPanel>
                            <ComboBox
                                x:Name="StartupLocationComboBox"
                                Grid.Column="2"
                                Style="{StaticResource SettingsComboBoxStyle}"
                                SelectedIndex="0"
                                SelectionChanged="StartupLocationComboBox_SelectionChanged">
                                <ComboBoxItem x:Name="StartupThisPcComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[SettingsStartupUseThisPc]}" />
                                <ComboBoxItem x:Name="StartupLastLocationComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[SettingsStartupLastLocation]}" />
                                <ComboBoxItem x:Name="StartupSpecifiedLocationComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[SettingsStartupSpecifiedLocation]}" />
                            </ComboBox>
                        </Grid>
                        <Grid
                            x:Name="StartupSpecifiedPathPanel"
                            Margin="0,16,0,0"
                            RowDefinitions="Auto,Auto"
                            Visibility="Collapsed">
                            <Border
                                x:Name="StartupSpecifiedPathSeparator"
                                Height="1"
                                Margin="0,0,0,16"
                                Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <Grid
                                Grid.Row="1"
                                ColumnDefinitions="*"
                                ColumnSpacing="8">
                                <StackPanel Margin="42,0,24,0" Spacing="8">
                                    <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsStartupSpecifiedPathDescription]}" />
                                    <Grid
                                        x:Name="StartupSpecifiedCustomPathPanel"
                                        ColumnDefinitions="*,Auto"
                                        ColumnSpacing="8">
                                        <TextBox
                                            x:Name="StartupSpecifiedPathTextBox"
                                            HorizontalAlignment="Stretch"
                                            PlaceholderText="{Binding Source={StaticResource Strings}, Path=[SettingsStartupSpecifiedPathPlaceholder]}"
                                            TextChanged="StartupSpecifiedPathTextBox_TextChanged" />
                                        <Button
                                            x:Name="StartupBrowseButton"
                                            Grid.Column="1"
                                            Style="{StaticResource SettingsActionButtonStyle}"
                                            Click="StartupBrowseButton_Click"
                                            Content="{Binding Source={StaticResource Strings}, Path=[SettingsBrowseFolder]}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE718;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsFavoritesTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsFavoritesDescription]}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="FavoritesToggleSwitch"
                            Grid.Column="2"
                            Style="{StaticResource SettingsToggleSwitchStyle}"
                            IsOn="True"
                            Toggled="SidebarSectionToggleSwitch_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE753;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsCloudTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsCloudDescription]}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="CloudToggleSwitch"
                            Grid.Column="2"
                            Style="{StaticResource SettingsToggleSwitchStyle}"
                            IsOn="True"
                            Toggled="SidebarSectionToggleSwitch_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE968;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsNetworkTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsNetworkDescription]}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="NetworkToggleSwitch"
                            Grid.Column="2"
                            Style="{StaticResource SettingsToggleSwitchStyle}"
                            IsOn="True"
                            Toggled="SidebarSectionToggleSwitch_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE8EC;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsTagsTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsTagsDescription]}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="TagsToggleSwitch"
                            Grid.Column="2"
                            Style="{StaticResource SettingsToggleSwitchStyle}"
                            IsOn="True"
                            Toggled="SidebarSectionToggleSwitch_Toggled" />
                    </Grid>
                </Border>

            </StackPanel>

            <StackPanel x:Name="AppearanceSection" Spacing="{StaticResource SettingsCardSpacing}">
                <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionAppearance]}" />
                <TextBlock Style="{StaticResource SettingsSectionDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionAppearanceDescription]}" />

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE790;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsThemeTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsThemeDescription]}" />
                        </StackPanel>
                        <ComboBox
                            x:Name="ThemePreferenceComboBox"
                            Grid.Column="2"
                            Style="{StaticResource SettingsComboBoxStyle}"
                            SelectedIndex="0"
                            SelectionChanged="ThemePreferenceComboBox_SelectionChanged">
                            <ComboBoxItem x:Name="ThemeUseSystemComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[SettingsUseSystem]}" />
                            <ComboBoxItem x:Name="ThemeLightComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[SettingsThemeLight]}" />
                            <ComboBoxItem x:Name="ThemeDarkComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[SettingsThemeDark]}" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE9D2;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSortTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSortDescription]}" />
                        </StackPanel>
                        <ComboBox
                            x:Name="DefaultSortComboBox"
                            Grid.Column="2"
                            Style="{StaticResource SettingsComboBoxStyle}"
                            SelectedIndex="0"
                            SelectionChanged="DefaultSortComboBox_SelectionChanged">
                            <ComboBoxItem x:Name="SortByNameComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[CommonSortByName]}" />
                            <ComboBoxItem x:Name="SortByModifiedDateComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[CommonSortByModifiedDate]}" />
                            <ComboBoxItem x:Name="SortByTypeComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[CommonSortByType]}" />
                            <ComboBoxItem x:Name="SortBySizeComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[CommonSortBySize]}" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE8FD;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsGroupTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsGroupDescription]}" />
                        </StackPanel>
                        <ComboBox
                            x:Name="DefaultGroupComboBox"
                            Grid.Column="2"
                            Style="{StaticResource SettingsComboBoxStyle}"
                            SelectedIndex="0"
                            SelectionChanged="DefaultGroupComboBox_SelectionChanged">
                            <ComboBoxItem x:Name="GroupByNoneComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[CommonGroupByNone]}" />
                            <ComboBoxItem x:Name="GroupByNameComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[CommonGroupByName]}" />
                            <ComboBoxItem x:Name="GroupByTypeComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[CommonGroupByType]}" />
                            <ComboBoxItem x:Name="GroupByModifiedDateComboBoxItem" Content="{Binding Source={StaticResource Strings}, Path=[CommonGroupByModifiedDate]}" />
                        </ComboBox>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel x:Name="FilesAndFoldersSection" Spacing="{StaticResource SettingsCardSpacing}">
                <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionFilesAndFolders]}" />
                <TextBlock Style="{StaticResource SettingsSectionDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionFilesAndFoldersDescription]}" />

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE8B7;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsShowHiddenTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsShowHiddenDescription]}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="ShowHiddenToggleSwitch"
                            Grid.Column="2"
                            Style="{StaticResource SettingsToggleSwitchStyle}"
                            IsOn="False"
                            Toggled="FileDisplayToggleSwitch_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE7BA;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsShowProtectedSystemTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsShowProtectedSystemDescription]}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="ShowProtectedSystemToggleSwitch"
                            Grid.Column="2"
                            Style="{StaticResource SettingsToggleSwitchStyle}"
                            IsOn="False"
                            Toggled="FileDisplayToggleSwitch_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE943;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsShowDotFilesTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsShowDotFilesDescription]}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="ShowDotFilesToggleSwitch"
                            Grid.Column="2"
                            Style="{StaticResource SettingsToggleSwitchStyle}"
                            IsOn="True"
                            Toggled="FileDisplayToggleSwitch_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE8A5;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsShowExtensionsTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsShowExtensionsDescription]}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="ShowFileExtensionsToggleSwitch"
                            Grid.Column="2"
                            Style="{StaticResource SettingsToggleSwitchStyle}"
                            IsOn="True"
                            Toggled="FileDisplayToggleSwitch_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE7BA;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsDeleteConfirmTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsDeleteConfirmDescription]}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="DeleteConfirmToggleSwitch"
                            Grid.Column="2"
                            Style="{StaticResource SettingsToggleSwitchStyle}"
                            IsOn="True"
                            Toggled="DeleteConfirmToggleSwitch_Toggled" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel x:Name="ShortcutsSection" Spacing="{StaticResource SettingsCardSpacing}">
                <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionShortcuts]}" />
                <TextBlock Style="{StaticResource SettingsSectionDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionShortcutsDescription]}" />

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE765;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsShortcutsTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsShortcutsDescription]}" />
                        </StackPanel>
                        <Button Grid.Column="2" Style="{StaticResource SettingsActionButtonStyle}" Content="{Binding Source={StaticResource Strings}, Path=[SettingsComingSoon]}" IsEnabled="False" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel x:Name="TagsSection" Spacing="{StaticResource SettingsCardSpacing}">
                <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionTags]}" />
                <TextBlock Style="{StaticResource SettingsSectionDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionTagsDescription]}" />

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE8EC;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsTagsFeatureTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsTagsFeatureDescription]}" />
                        </StackPanel>
                        <Button Grid.Column="2" Style="{StaticResource SettingsActionButtonStyle}" Content="{Binding Source={StaticResource Strings}, Path=[SettingsComingSoon]}" IsEnabled="False" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel x:Name="AdvancedSection" Spacing="{StaticResource SettingsCardSpacing}">
                <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionAdvanced]}" />
                <TextBlock Style="{StaticResource SettingsSectionDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionAdvancedDescription]}" />

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsMigrationTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsMigrationDescription]}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button
                                x:Name="ExportSettingsButton"
                                Style="{StaticResource SettingsActionButtonStyle}"
                                Click="ExportSettingsButton_Click"
                                Content="{Binding Source={StaticResource Strings}, Path=[SettingsExport]}" />
                            <Button
                                x:Name="ImportSettingsButton"
                                Style="{StaticResource SettingsActionButtonStyle}"
                                Click="ImportSettingsButton_Click"
                                Content="{Binding Source={StaticResource Strings}, Path=[SettingsImport]}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE7E8;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsAutoStartTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsAutoStartDescription]}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="AutoStartToggleSwitch"
                            Grid.Column="2"
                            Style="{StaticResource SettingsToggleSwitchStyle}"
                            IsOn="False"
                            Toggled="AutoStartToggleSwitch_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE7F4;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsMinimizeToTrayTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsMinimizeToTrayDescription]}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="MinimizeToTrayToggleSwitch"
                            Grid.Column="2"
                            Style="{StaticResource SettingsToggleSwitchStyle}"
                            IsOn="False"
                            Toggled="MinimizeToTrayToggleSwitch_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Glyph="&#xE8D4;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="0" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock Style="{StaticResource SettingsItemHeaderStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsDefaultManagerTitle]}" />
                            <TextBlock Style="{StaticResource SettingsItemDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsDefaultManagerDescription]}" />
                        </StackPanel>
                        <Button Grid.Column="2" Style="{StaticResource SettingsActionButtonStyle}" Content="{Binding Source={StaticResource Strings}, Path=[SettingsSetDefault]}" IsEnabled="False" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel x:Name="AboutSection" Spacing="{StaticResource SettingsCardSpacing}">
                <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionAbout]}" />
                <TextBlock Style="{StaticResource SettingsSectionDescriptionStyle}" Text="{Binding Source={StaticResource Strings}, Path=[SettingsSectionAboutDescription]}" />

                <Border Style="{StaticResource SettingsItemCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Border Style="{StaticResource SettingsIconHostStyle}">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe Fluent Icons"
                                Glyph="&#xE8B7;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="6" Style="{StaticResource SettingsItemTextHostStyle}">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Source={StaticResource Strings}, Path=[SettingsAboutAppName]}" />
                            <TextBlock Opacity="0.72" Text="{Binding Source={StaticResource Strings}, Path=[SettingsAboutAppDescription]}" TextWrapping="WrapWholeWords" />
                            <TextBlock x:Name="EngineVersionTextBlock" Opacity="0.72" />
                            <TextBlock x:Name="AppVersionTextBlock" Opacity="0.72" />
                        </StackPanel>
                        <FontIcon
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            Glyph="&#xE76C;"
                            Opacity="0.55" />
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
