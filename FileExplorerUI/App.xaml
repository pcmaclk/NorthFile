<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="FileExplorerUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileExplorerUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Themes/Generic.xaml" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="BreadcrumbMenuFlyoutPresenterStyle" TargetType="MenuFlyoutPresenter">
                <Setter Property="MaxHeight" Value="360" />
            </Style>
            <Style
                x:Key="ContextPrototypeFlyoutPresenterStyle"
                TargetType="FlyoutPresenter"
                BasedOn="{StaticResource DefaultFlyoutPresenterStyle}">
                <Setter Property="Padding" Value="4" />
            </Style>

            <Style x:Key="ContextMenuFlyoutPresenterStyle" TargetType="MenuFlyoutPresenter" BasedOn="{StaticResource DefaultMenuFlyoutPresenterStyle}" />
            <Style x:Key="ContextMenuFlyoutItemStyle" TargetType="MenuFlyoutItem" BasedOn="{StaticResource DefaultMenuFlyoutItemStyle}" />
            <Style x:Key="ContextMenuFlyoutSubItemStyle" TargetType="MenuFlyoutSubItem" BasedOn="{StaticResource DefaultMenuFlyoutSubItemStyle}" />
            <Style x:Key="CompactSidebarMenuFlyoutPresenterStyle" TargetType="MenuFlyoutPresenter">
                <Setter Property="MinWidth" Value="240" />
                <Setter Property="Shadow" Value="{x:Null}" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="ScrollViewer.VerticalScrollMode" Value="Auto" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
            </Style>
            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
