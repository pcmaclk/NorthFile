<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FileExplorerUI.SidebarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:FileExplorerUI.Controls"
    xmlns:local="using:FileExplorerUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Thickness x:Key="TreeViewItemBorderThemeThickness">0</Thickness>
        <Thickness x:Key="TreeViewItemPresenterMargin">0,2,0,2</Thickness>
        <Thickness x:Key="TreeViewItemPresenterPadding">0</Thickness>
        <Thickness x:Key="TreeViewItemMultiSelectSelectedItemBorderMargin">0</Thickness>
        <x:Double x:Key="TreeViewItemMinHeight">32</x:Double>
        <x:Double x:Key="TreeViewItemMultiSelectCheckBoxMinHeight">32</x:Double>
        <x:Double x:Key="TreeViewItemContentHeight">32</x:Double>
        <DataTemplate x:Key="SidebarPinnedItemTemplate" x:DataType="local:SidebarNavItemModel">
            <Grid>
                <Border
                    Height="2"
                    Margin="14,0,0,0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource TreeViewItemSelectionIndicatorForeground}"
                    CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                    Visibility="{x:Bind DragInsertBeforeVisibility, Mode=OneWay}" />
                <Border
                    Height="2"
                    Margin="14,0,0,0"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource TreeViewItemSelectionIndicatorForeground}"
                    CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                    Visibility="{x:Bind DragInsertAfterVisibility, Mode=OneWay}" />
                <controls:EntryItemHost
                    Margin="0,2,0,2"
                    MinHeight="32"
                    Padding="0,3,0,3"
                    Background="Transparent"
                    IndicatorBrush="{ThemeResource TreeViewItemSelectionIndicatorForeground}"
                    IsSelected="{x:Bind IsSelected, Mode=OneWay}"
                    HorizontalAlignment="Stretch"
                    Loaded="PinnedItemHost_Loaded"
                    Unloaded="PinnedItemHost_Unloaded"
                    PointerPressed="PinnedItemHost_PointerPressed"
                    PointerMoved="PinnedItemHost_PointerMoved"
                    PointerReleased="PinnedItemHost_PointerReleased"
                    PointerCaptureLost="PinnedItemHost_PointerCaptureLost"
                    Tapped="PinnedItemHost_Tapped"
                    ContextRequested="PinnedItemHost_ContextRequested">
                    <Grid Margin="10,0,0,0" Height="26" ColumnDefinitions="32,12,*,26" ColumnSpacing="0">
                        <FontIcon
                            Grid.Column="1"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="{x:Bind Glyph}" />
                        <TextBlock
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Text="{x:Bind Label}"
                            TextTrimming="CharacterEllipsis" />
                        <FontIcon
                            Grid.Column="3"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Opacity="0.72"
                            Glyph="&#xE718;" />
                    </Grid>
                </controls:EntryItemHost>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="SidebarStaticEntryItemTemplate" x:DataType="local:SidebarNavItemModel">
            <Grid>
                <controls:EntryItemHost
                    Margin="0,2,0,2"
                    MinHeight="32"
                    Padding="0,3,0,3"
                    Background="Transparent"
                    IndicatorBrush="{ThemeResource TreeViewItemSelectionIndicatorForeground}"
                    IsSelected="{x:Bind IsSelected, Mode=OneWay}"
                    HorizontalAlignment="Stretch"
                    IsHitTestVisible="False">
                    <Grid Margin="10,0,0,0" Height="26" ColumnDefinitions="32,12,*" ColumnSpacing="0">
                        <FontIcon
                            Grid.Column="1"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="{x:Bind Glyph}" />
                        <TextBlock
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Text="{x:Bind Label}"
                            TextTrimming="CharacterEllipsis" />
                    </Grid>
                </controls:EntryItemHost>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" RowDefinitions="*,Auto">
        <ScrollViewer x:Name="SidebarScrollViewer" Padding="0,0,12,8" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="RootStackPanel" Margin="0,4,0,0" Spacing="0">
                <StackPanel x:Name="CompactButtonsPanel" Spacing="6" Visibility="Collapsed" />

            <StackPanel x:Name="PinnedSectionPanel" Margin="0,0,0,0" Spacing="2">
                <Border
                    x:Name="PinnedGroupBorder"
                    Margin="0,2"
                    Background="Transparent"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    PointerPressed="PinnedGroup_Click"
                    >
                    <Grid x:Name="PinnedGroupGrid" ColumnDefinitions="14,12,*,26" ColumnSpacing="0"
                          Padding="4, 0, 0, 0">
                        <Border
                            x:Name="PinnedGroupSelectionIndicator"
                            Width="3"
                            Margin="0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="{ThemeResource TreeViewItemSelectionIndicatorForeground}"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Visibility="Collapsed" />
                        <FontIcon
                            x:Name="PinnedGroupIcon"
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE734;" />
                        <TextBlock
                            x:Name="PinnedGroupTextBlock"
                            x:Uid="PinnedGroupTextBlock"
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center" />
                        <FontIcon
                            x:Name="PinnedChevron"
                            Grid.Column="3"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE70E;" />
                    </Grid>
                </Border>

                <ItemsControl
                    x:Name="PinnedItemsPanel"
                    ItemTemplate="{StaticResource SidebarPinnedItemTemplate}"
                    ItemsSource="{x:Bind PinnedItems, Mode=OneWay}"
                    Visibility="Visible" />
            </StackPanel>

            <StackPanel x:Name="TreeSectionPanel" Margin="0,6,0,0" Spacing="2">
                <Border
                    x:Name="TreeCompactBorder"
                    Margin="0,2"
                    Padding="4,4"
                    Background="Transparent"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    PointerPressed="TreeCompactBorder_PointerPressed"
                    Visibility="Collapsed">
                    <Grid x:Name="TreeCompactGrid" ColumnDefinitions="14,12,*,26" ColumnSpacing="0">
                        <Border
                            x:Name="TreeCompactSelectionIndicator"
                            Width="3"
                            Margin="0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="{ThemeResource TreeViewItemSelectionIndicatorForeground}"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Visibility="Collapsed" />
                        <FontIcon
                            x:Name="TreeCompactIcon"
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE7F4;" />
                    </Grid>
                </Border>
                <Border
                    x:Name="TreeHostBorder"
                    Padding="0"
                    Background="Transparent"
                    CornerRadius="{ThemeResource OverlayCornerRadius}">
                    <Grid x:Name="TreeHostGrid" />
                </Border>
            </StackPanel>

            <StackPanel x:Name="CloudSectionPanel" Margin="0,6,0,0" Spacing="2">
                <Border
                    x:Name="CloudGroupBorder"
                    Margin="0,2"
                    Padding="4,4"
                    Background="Transparent"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    PointerPressed="CloudGroup_Click">
                    <Grid x:Name="CloudGroupGrid" ColumnDefinitions="14,12,*,26" ColumnSpacing="0"
                          Padding="4, 0, 0, 0">
                        <Border
                            x:Name="CloudGroupSelectionIndicator"
                            Width="3"
                            Margin="0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="{ThemeResource TreeViewItemSelectionIndicatorForeground}"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Visibility="Collapsed" />
                        <FontIcon
                            x:Name="CloudGroupIcon"
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE753;" />
                        <TextBlock
                            x:Name="CloudHeaderTextBlock"
                            x:Uid="CloudHeaderTextBlock"
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center" />
                        <FontIcon
                            x:Name="CloudChevron"
                            Grid.Column="3"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE70E;" />
                    </Grid>
                </Border>
                <ItemsControl
                    x:Name="CloudItemsPanel"
                    IsHitTestVisible="False"
                    ItemTemplate="{StaticResource SidebarStaticEntryItemTemplate}"
                    ItemsSource="{x:Bind CloudItems, Mode=OneWay}" />
            </StackPanel>

            <StackPanel x:Name="NetworkSectionPanel" Margin="0,6,0,0" Spacing="2">
                <Border
                    x:Name="NetworkGroupBorder"
                    Margin="0,2"
                    Padding="4,4"
                    Background="Transparent"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    PointerPressed="NetworkGroup_Click">
                    <Grid x:Name="NetworkGroupGrid" ColumnDefinitions="14,12,*,26" ColumnSpacing="0"
                          Padding="4, 0, 0, 0">
                        <Border
                            x:Name="NetworkGroupSelectionIndicator"
                            Width="3"
                            Margin="0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="{ThemeResource TreeViewItemSelectionIndicatorForeground}"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Visibility="Collapsed" />
                        <FontIcon
                            x:Name="NetworkGroupIcon"
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE774;" />
                        <TextBlock
                            x:Name="NetworkHeaderTextBlock"
                            x:Uid="NetworkHeaderTextBlock"
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center" />
                        <FontIcon
                            x:Name="NetworkChevron"
                            Grid.Column="3"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE70E;" />
                    </Grid>
                </Border>
                <ItemsControl
                    x:Name="NetworkItemsPanel"
                    IsHitTestVisible="False"
                    ItemTemplate="{StaticResource SidebarStaticEntryItemTemplate}"
                    ItemsSource="{x:Bind NetworkItems, Mode=OneWay}"
                    Visibility="Collapsed" />
            </StackPanel>

            <StackPanel x:Name="TagsSectionPanel" Margin="0,6,0,0" Spacing="2">
                <Border
                    x:Name="TagsGroupBorder"
                    Margin="0,2"
                    Padding="4,4"
                    Background="Transparent"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    PointerPressed="TagsGroup_Click">
                    <Grid x:Name="TagsGroupGrid" ColumnDefinitions="14,12,*,26" ColumnSpacing="0"
                          Padding="4, 0, 0, 0">
                        <Border
                            x:Name="TagsGroupSelectionIndicator"
                            Width="3"
                            Margin="0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="{ThemeResource TreeViewItemSelectionIndicatorForeground}"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Visibility="Collapsed" />
                        <FontIcon
                            x:Name="TagsGroupIcon"
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE8EC;" />
                        <TextBlock
                            x:Name="TagsHeaderTextBlock"
                            x:Uid="TagsHeaderTextBlock"
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center" />
                        <FontIcon
                            x:Name="TagsChevron"
                            Grid.Column="3"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE70E;" />
                    </Grid>
                </Border>
                <ItemsControl
                    x:Name="TagsItemsPanel"
                    IsHitTestVisible="False"
                    ItemTemplate="{StaticResource SidebarStaticEntryItemTemplate}"
                    ItemsSource="{x:Bind TagItems, Mode=OneWay}" />
            </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="SettingsFooterHost" Grid.Row="1" Height="32" Margin="0,0,12,2" Visibility="Collapsed">
            <Button
                x:Name="SidebarSettingsButton"
                Width="Auto"
                Height="32"
                Padding="9,0,0,0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                VerticalAlignment="Center"
                Style="{ThemeResource SubtleButtonStyle}"
                Click="SidebarSettingsButton_Click">
                <ToolTipService.ToolTip>
                    <ToolTip x:Uid="SidebarSettingsButtonToolTip" />
                </ToolTipService.ToolTip>
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE713;" />
            </Button>
        </Grid>

        <Canvas x:Name="PinnedDragOverlayCanvas" IsHitTestVisible="False">
            <Border
                x:Name="PinnedDragPreviewHost"
                Width="44"
                Height="44"
                CornerRadius="8"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                Opacity="0.96"
                Visibility="Collapsed">
                <Grid>
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="18"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        Glyph="&#xE8B7;" />
                </Grid>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
