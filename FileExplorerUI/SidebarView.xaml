<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FileExplorerUI.SidebarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,8,12,12" Spacing="4">
            <!-- 固定项组标题（可点击展开/折叠） -->
            <Border
                x:Name="PinnedGroupBorder"
                Margin="4,2,4,2"
                Padding="0,4,0,4"
                CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                Background="Transparent"
                PointerPressed="PinnedGroup_Click">
                <Grid ColumnDefinitions="14,12,*,26" ColumnSpacing="0">
                    <Border
                        x:Name="PinnedGroupSelectionIndicator"
                        Width="3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Margin="0,2"
                        CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                        Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                        Visibility="Collapsed" />
                    <FontIcon
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="10"
                        Glyph="&#xE718;" />
                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Margin="14,0,0,0"
                        Text="固定" />
                    <FontIcon
                        x:Name="PinnedChevron"
                        Grid.Column="3"
                        Width="12"
                        Height="12"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="10"
                        Glyph="&#xE70E;" />
                </Grid>
            </Border>

            <!-- 固定项列表（展开/折叠） -->
            <StackPanel
                x:Name="PinnedItemsPanel"
                Visibility="Visible">
                <!-- 桌面 -->
                <Border
                    x:Name="DesktopItemBorder"
                    Margin="4,2,4,2"
                    Padding="0,4,0,4"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    Background="Transparent"
                    PointerPressed="PinnedItem_Click">
                    <Grid ColumnDefinitions="30,12,*" ColumnSpacing="0">
                        <Border
                            x:Name="DesktopSelectionIndicator"
                            Width="3"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Margin="0,2"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                            Visibility="Collapsed" />
                        <FontIcon
                            Grid.Column="1"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE80F;" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0"
                            Text="桌面" />
                    </Grid>
                </Border>

                <!-- 文档 -->
                <Border
                    x:Name="DocumentsItemBorder"
                    Margin="4,2,4,2"
                    Padding="0,4,0,4"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    Background="Transparent"
                    PointerPressed="PinnedItem_Click">
                    <Grid ColumnDefinitions="30,12,*" ColumnSpacing="0">
                        <Border
                            x:Name="DocumentsSelectionIndicator"
                            Width="3"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Margin="0,2"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                            Visibility="Collapsed" />
                        <FontIcon
                            Grid.Column="1"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE8A5;" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0"
                            Text="文档" />
                    </Grid>
                </Border>

                <!-- 下载 -->
                <Border
                    x:Name="DownloadsItemBorder"
                    Margin="4,2,4,2"
                    Padding="0,4,0,4"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    Background="Transparent"
                    PointerPressed="PinnedItem_Click">
                    <Grid ColumnDefinitions="30,12,*" ColumnSpacing="0">
                        <Border
                            x:Name="DownloadsSelectionIndicator"
                            Width="3"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Margin="0,2"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                            Visibility="Collapsed" />
                        <FontIcon
                            Grid.Column="1"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE896;" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0"
                            Text="下载" />
                    </Grid>
                </Border>

                <!-- 图片 -->
                <Border
                    x:Name="PicturesItemBorder"
                    Margin="4,2,4,2"
                    Padding="0,4,0,4"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    Background="Transparent"
                    PointerPressed="PinnedItem_Click">
                    <Grid ColumnDefinitions="30,12,*" ColumnSpacing="0">
                        <Border
                            x:Name="PicturesSelectionIndicator"
                            Width="3"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Margin="0,2"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                            Visibility="Collapsed" />
                        <FontIcon
                            Grid.Column="1"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE91B;" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0"
                            Text="图片" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- 文件树 -->
            <TreeView
                x:Name="SidebarTreeView"
                Margin="0,8,0,0"
                HorizontalAlignment="Stretch"
                ScrollViewer.VerticalScrollMode="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                ScrollViewer.HorizontalScrollMode="Disabled"
                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                SelectionMode="Single">
                <TreeView.RootNodes>
                    <TreeViewNode Content="电脑" IsExpanded="True">
                        <TreeViewNode.Children>
                            <TreeViewNode Content="桌面" />
                            <TreeViewNode Content="文档" />
                            <TreeViewNode Content="下载" />
                            <TreeViewNode Content="图片" />
                            <TreeViewNode Content="本地磁盘 (C:)" IsExpanded="True">
                                <TreeViewNode.Children>
                                    <TreeViewNode Content="Program Files" />
                                    <TreeViewNode Content="Users" IsExpanded="True">
                                        <TreeViewNode.Children>
                                            <TreeViewNode Content="Demo" IsExpanded="True">
                                                <TreeViewNode.Children>
                                                    <TreeViewNode Content="Desktop" />
                                                    <TreeViewNode Content="Documents" />
                                                    <TreeViewNode Content="Downloads" />
                                                    <TreeViewNode Content="Pictures" />
                                                </TreeViewNode.Children>
                                            </TreeViewNode>
                                        </TreeViewNode.Children>
                                    </TreeViewNode>
                                </TreeViewNode.Children>
                            </TreeViewNode>
                            <TreeViewNode Content="数据盘 (D:)" IsExpanded="True">
                                <TreeViewNode.Children>
                                    <TreeViewNode Content="NorthFile" />
                                    <TreeViewNode Content="Samples" />
                                    <TreeViewNode Content="Archive" />
                                </TreeViewNode.Children>
                            </TreeViewNode>
                        </TreeViewNode.Children>
                    </TreeViewNode>
                </TreeView.RootNodes>
            </TreeView>
        </StackPanel>
    </ScrollViewer>
</UserControl>