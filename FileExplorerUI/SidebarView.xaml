<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FileExplorerUI.SidebarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Thickness x:Key="TreeViewItemPresenterMargin">0</Thickness>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="RootStackPanel" Margin="0,8,0,12" Spacing="2">
            <Border
                x:Name="PinnedGroupBorder"
                Margin="0,2"
                Padding="0,4"
                Background="Transparent"
                CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                PointerPressed="PinnedGroup_Click">
                <Grid ColumnDefinitions="14,12,*,26" ColumnSpacing="0">
                    <Border
                        x:Name="PinnedGroupSelectionIndicator"
                        Width="3"
                        Margin="0,2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                        CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                        Visibility="Collapsed" />
                    <FontIcon
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="10"
                        Glyph="&#xE718;" />
                    <TextBlock
                        x:Name="PinnedGroupTextBlock"
                        Grid.Column="2"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        Text="固定" />
                    <FontIcon
                        x:Name="PinnedChevron"
                        Grid.Column="3"
                        Width="12"
                        Height="12"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="10"
                        Glyph="&#xE70E;" />
                </Grid>
            </Border>

            <StackPanel x:Name="PinnedItemsPanel" Visibility="Visible">
                <Border
                    x:Name="DesktopItemBorder"
                    Margin="0,2"
                    Padding="0,4"
                    Background="Transparent"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    PointerPressed="PinnedItem_Click"
                    Tag="Desktop">
                    <Grid ColumnDefinitions="30,12,*" ColumnSpacing="0">
                        <Border
                            x:Name="DesktopSelectionIndicator"
                            Width="3"
                            Margin="0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Visibility="Collapsed" />
                        <FontIcon
                            Grid.Column="1"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE80F;" />
                        <TextBlock
                            x:Name="DesktopTextBlock"
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Text="桌面" />
                    </Grid>
                </Border>

                <Border
                    x:Name="DocumentsItemBorder"
                    Margin="0,2"
                    Padding="0,4"
                    Background="Transparent"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    PointerPressed="PinnedItem_Click"
                    Tag="Documents">
                    <Grid ColumnDefinitions="30,12,*" ColumnSpacing="0">
                        <Border
                            x:Name="DocumentsSelectionIndicator"
                            Width="3"
                            Margin="0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Visibility="Collapsed" />
                        <FontIcon
                            Grid.Column="1"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE8A5;" />
                        <TextBlock
                            x:Name="DocumentsTextBlock"
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Text="文档" />
                    </Grid>
                </Border>

                <Border
                    x:Name="DownloadsItemBorder"
                    Margin="0,2"
                    Padding="0,4"
                    Background="Transparent"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    PointerPressed="PinnedItem_Click"
                    Tag="Downloads">
                    <Grid ColumnDefinitions="30,12,*" ColumnSpacing="0">
                        <Border
                            x:Name="DownloadsSelectionIndicator"
                            Width="3"
                            Margin="0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Visibility="Collapsed" />
                        <FontIcon
                            Grid.Column="1"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE896;" />
                        <TextBlock
                            x:Name="DownloadsTextBlock"
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Text="下载" />
                    </Grid>
                </Border>

                <Border
                    x:Name="PicturesItemBorder"
                    Margin="0,2"
                    Padding="0,4"
                    Background="Transparent"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}"
                    PointerPressed="PinnedItem_Click"
                    Tag="Pictures">
                    <Grid ColumnDefinitions="30,12,*" ColumnSpacing="0">
                        <Border
                            x:Name="PicturesSelectionIndicator"
                            Width="3"
                            Margin="0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Visibility="Collapsed" />
                        <FontIcon
                            Grid.Column="1"
                            Width="12"
                            Height="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Glyph="&#xE91B;" />
                        <TextBlock
                            x:Name="PicturesTextBlock"
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Text="图片" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel x:Name="TreeSectionPanel" Margin="0,6,0,0" Spacing="2">
                <Border
                    Padding="0"
                    Background="Transparent"
                    CornerRadius="{ThemeResource OverlayCornerRadius}">
                    <Grid x:Name="TreeHostGrid" />
                </Border>
            </StackPanel>

            <StackPanel x:Name="ExtrasSectionPanel" Margin="0,6,0,0" Spacing="2">
                <Border
                    x:Name="ExtrasGroupBorder"
                    Margin="0,2"
                    Padding="0,4"
                    Background="Transparent"
                    CornerRadius="{ThemeResource ListViewItemCornerRadius}">
                    <Grid ColumnDefinitions="14,12,*,26" ColumnSpacing="0">
                        <Border
                            x:Name="ExtrasGroupSelectionIndicator"
                            Width="3"
                            Margin="0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                            CornerRadius="{ThemeResource ListViewItemSelectionIndicatorCornerRadius}"
                            Visibility="Collapsed" />
                        <FontIcon
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="10"
                            Glyph="&#xE712;" />
                        <TextBlock
                            x:Name="ExtrasHeaderTextBlock"
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Text="其他" />
                    </Grid>
                </Border>
                <StackPanel x:Name="ExtrasItemsPanel" Spacing="2" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
