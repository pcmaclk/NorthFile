                                            Margin="0,0,6,0"
                                            Style="{StaticResource DetailsHeaderHitTargetStyle}"
                                            PointerEntered="SecondaryDetailsHeader_PointerEntered"
                                            PointerExited="SecondaryDetailsHeader_PointerExited"
                                            PointerPressed="SecondaryDetailsHeader_PointerPressed"
                                            Tag="ModifiedDate">
                                            <Grid Margin="14,0,0,0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    x:Name="SecondaryModifiedHeaderTextBlock"
                                                    Style="{StaticResource DetailsHeaderTextStyle}" />
                                                <TextBlock
                                                    x:Name="SecondaryModifiedHeaderSortGlyphTextBlock"
                                                    Grid.Column="2"
                                                    Style="{StaticResource DetailsHeaderSortGlyphStyle}" />
                                            </Grid>
                                        </Border>
                                        <local:ColumnSplitter
                                            x:Name="SecondaryHeaderSplitter1"
                                            Grid.Column="1"
                                            GuideBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            Tag="S1"
                                            PointerEntered="ColumnSplitterHover_PointerEntered"
                                            PointerExited="ColumnSplitterHover_PointerExited" />
                                        <local:ColumnSplitter
                                            x:Name="SecondaryHeaderSplitter2"
                                            Grid.Column="3"
                                            GuideBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            Tag="S2"
                                            PointerEntered="ColumnSplitterHover_PointerEntered"
                                            PointerExited="ColumnSplitterHover_PointerExited" />
                                        <local:ColumnSplitter
                                            x:Name="SecondaryHeaderSplitter3"
                                            Grid.Column="5"
                                            GuideBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            Tag="S3"
                                            PointerEntered="ColumnSplitterHover_PointerEntered"
                                            PointerExited="ColumnSplitterHover_PointerExited" />
                                        <local:ColumnSplitter
                                            x:Name="SecondaryHeaderSplitter4"
                                            Grid.ColumnSpan="7"
                                            HorizontalAlignment="Right"
                                            GuideBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            Tag="S4"
                                            PointerEntered="ColumnSplitterHover_PointerEntered"
                                            PointerExited="ColumnSplitterHover_PointerExited" />
                                    </Grid>
                                </Border>

                                <ScrollViewer
                                    x:Name="SecondaryEntriesScrollViewer"
                                    Grid.Row="1"
                                    Style="{StaticResource EntryListScrollViewerStyle}"
                                    HorizontalScrollBarVisibility="Auto"
                                    HorizontalScrollMode="Enabled"
                                    VerticalScrollBarVisibility="Visible"
                                    VerticalScrollMode="Enabled"
                                    DoubleTapped="SecondaryEntriesView_DoubleTapped"
                                    PointerPressed="SecondaryPaneSurface_PointerPressed"
                                    RightTapped="SecondaryEntriesView_RightTapped"
                                    Visibility="{x:Bind SecondaryPaneItemsVisibility, Mode=OneWay}">
                                    <ItemsRepeater
                                        x:Name="SecondaryEntriesRepeater"
                                        ItemsSource="{x:Bind SecondaryPaneEntries, Mode=OneWay}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <controls:EntryItemHost
                                                    Style="{StaticResource DetailsEntryItemHostStyle}"
                                                    Width="{Binding ElementName=RootWindow, Path=SecondaryDetailsRowWidth}"
                                                    MinHeight="{Binding ElementName=RootWindow, Path=EntryItemMetrics.RowHeight}"
                                                    IsSelected="{Binding IsExplicitlySelected, Mode=OneWay}"
                                                    IsAnchorFocused="{Binding IsKeyboardAnchor, Mode=OneWay}"
                                                    PointerPressed="SecondaryEntryRow_PointerPressed"
                                                    RightTapped="SecondaryEntryRow_RightTapped"
                                                    SelectedBackground="{Binding RowBackground}"
                                                    SelectedPointerOverBackground="{Binding RowBackground}"
                                                    SelectedPressedBackground="{Binding RowBackground}"
                                                    Loaded="SecondaryEntryRow_Loaded">
                                                    <Grid
                                                        Margin="6,0,0,0"
                                                        HorizontalAlignment="Stretch"
                                                        Loaded="SecondaryDetailsRowGrid_Loaded">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=SecondaryNameColumnWidth}" MinWidth="120" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=SecondaryTypeColumnWidth}" MinWidth="90" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=SecondarySizeColumnWidth}" MinWidth="80" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=SecondaryModifiedColumnWidth}" MinWidth="120" />
                                                        </Grid.ColumnDefinitions>
                                                        <controls:EntryNameCell
                                                            Grid.Column="0"
                                                            ContentMargin="{Binding ElementName=RootWindow, Path=DetailsNameCellMargin}"
                                                            Entry="{Binding}"
                                                            Metrics="{Binding ElementName=RootWindow, Path=EntryItemMetrics}"
                                                            VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="2" Style="{StaticResource DetailsCellTextStyle}" Text="{Binding Type}" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="4" Style="{StaticResource DetailsCellTextStyle}" Text="{Binding SizeText}" />
                                                        <TextBlock Grid.Column="6" Style="{StaticResource DetailsCellTextStyle}" Text="{Binding ModifiedText}" />
                                                    </Grid>
                                                </controls:EntryItemHost>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </ScrollViewer>

                                <TextBlock
                                    Grid.RowSpan="2"
                                    HorizontalAlignment="Center"
                                    Foreground="{ThemeResource InactivePaneForegroundBrush}"
                                    VerticalAlignment="Center"
                                    Opacity="0.72"
                                    Visibility="{x:Bind SecondaryPanePlaceholderVisibility, Mode=OneWay}"
                                    Text="{x:Bind SecondaryPanePlaceholderText, Mode=OneWay}" />
                            </Grid>
                        </Border>
                    </Grid>

                    <Canvas
                        x:Name="RenameOverlayCanvas"
                        Grid.ColumnSpan="3"
                        Margin="0,8,0,0"
                        IsHitTestVisible="True">
                        <Border
                            x:Name="RenameOverlayBorder"
                            Style="{StaticResource RenameOverlayBorderStyle}"
                            Visibility="Collapsed">
                            <TextBox
                                x:Name="RenameOverlayTextBox"
                                BeforeTextChanging="RenameOverlayTextBox_BeforeTextChanging"
                                KeyDown="RenameOverlayTextBox_KeyDown"
                                LostFocus="RenameOverlayTextBox_LostFocus"
                                TextChanging="RenameOverlayTextBox_TextChanging"
                                Style="{StaticResource RenameOverlayTextBoxStyle}" />
                        </Border>
                    </Canvas>
                </Grid>

                <Grid Grid.Row="1" Height="{x:Bind ShellStatusBarHeight, Mode=OneWay}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="PrimaryStatusPaneColumn" Width="{x:Bind ExplorerPanePrimaryColumnWidth, Mode=OneWay}" />
                        <ColumnDefinition x:Name="ExplorerPaneActionRailStatusColumn" Width="{x:Bind ExplorerPaneActionRailColumnWidth, Mode=OneWay}" />
                        <ColumnDefinition x:Name="SecondaryStatusPaneColumn" Width="{x:Bind ExplorerPaneSecondaryColumnWidth, Mode=OneWay}" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="PrimaryStatusTextBlock"
                        Margin="{x:Bind ShellStatusTextMargin, Mode=OneWay}"
                        Style="{StaticResource PaneStatusTextStyle}"
                        Text="{x:Bind PrimaryPaneStatusText, Mode=OneWay}"
                        />
                    <TextBlock
                        x:Name="SecondaryStatusTextBlock"
                        Grid.Column="2"
                        Margin="{x:Bind ShellStatusTextMargin, Mode=OneWay}"
                        Style="{StaticResource PaneStatusTextStyle}"
                        Text="{x:Bind SecondaryPaneStatusText, Mode=OneWay}"
                        Visibility="{x:Bind ExplorerSecondaryPaneVisibility, Mode=OneWay}" />
                </Grid>
        </Grid>
        </Grid>

        <!-- Settings shell uses its own drag region and overlays the explorer shell below. -->
        <Grid
            x:Name="SettingsTitleBarDragRegion"
            Grid.ColumnSpan="2"
            Height="{x:Bind ShellTitleBarHeight, Mode=OneWay}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            Background="Transparent"
            Loaded="TitleBarDragRegion_Loaded"
            SizeChanged="TitleBarDragRegion_SizeChanged"
            Visibility="{x:Bind SettingsShellVisibility, Mode=OneWay}" />

        <StackPanel Grid.RowSpan="3" Grid.ColumnSpan="2" Visibility="Collapsed">
            <TextBlock
                x:Name="TitleBarPrimaryBrushProbe"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <TextBlock
                x:Name="TitleBarSecondaryBrushProbe"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
                x:Name="DetailsHeaderSecondaryBrushProbe"
                Foreground="{ThemeResource DetailsHeaderSecondaryForegroundBrush}" />
            <TextBlock
                x:Name="ActivePaneForegroundBrushProbe"
                Foreground="{ThemeResource ActivePaneForegroundBrush}" />
            <TextBlock
                x:Name="InactivePaneForegroundBrushProbe"
                Foreground="{ThemeResource InactivePaneForegroundBrush}" />
            <Border
                x:Name="ActiveTabBackgroundBrushProbe"
                Background="{ThemeResource TitleBarActiveTabPillBackgroundBrush}" />
            <Border
                x:Name="ActivePaneToolbarBrushProbe"
                Background="{ThemeResource ActivePaneSurfaceBackgroundBrush}"
                BorderBrush="{ThemeResource ActivePaneBorderBrush}" />
            <Border
                x:Name="InactivePaneToolbarBrushProbe"
                Background="{ThemeResource InactivePaneSurfaceBackgroundBrush}"
                BorderBrush="{ThemeResource InactivePaneBorderBrush}" />
            <Border
                x:Name="ActivePaneBodyBrushProbe"
                Background="{ThemeResource ActivePaneSurfaceBackgroundBrush}"
                BorderBrush="{ThemeResource ActivePaneBorderBrush}" />
            <Border
                x:Name="InactivePaneBodyBrushProbe"
                Background="{ThemeResource InactivePaneSurfaceBackgroundBrush}"
                BorderBrush="{ThemeResource InactivePaneBorderBrush}" />
            <Border
                x:Name="ActivePaneInputBrushProbe"
                Background="{ThemeResource ActivePaneInputBackgroundBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" />
            <Border
                x:Name="InactivePaneInputBrushProbe"
                Background="{ThemeResource InactivePaneInputBackgroundBrush}"
                BorderBrush="{ThemeResource AddressSearchChromeBorderBrush}" />
            <Button
                x:Name="NewFileButton"
                Click="NewFileButton_Click" />
            <Button
                x:Name="NewFolderButton"
                Click="NewFolderButton_Click" />
            <Button
                x:Name="CopyButton"
                Click="CopyButton_Click" />
            <Button
                x:Name="CutButton"
                Click="CutButton_Click" />
            <Button
                x:Name="PasteButton"
                Click="PasteButton_Click" />
        </StackPanel>

        <!-- Sidebar splitter sits on the content column edge so the guide overlays cleanly. -->
        <local:ColumnSplitter
            x:Name="SidebarSplitter"
            Grid.Row="2"
            Grid.Column="1"
            Width="{x:Bind ShellSplitterWidth, Mode=OneWay}"
            Margin="-4,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            ShowGuide="False"
            Visibility="{x:Bind ExplorerShellVisibility, Mode=OneWay}"
            PointerEntered="ColumnSplitterHover_PointerEntered"
            PointerExited="ColumnSplitterHover_PointerExited" />

        <!-- Settings shell overlays both columns and replaces the explorer workspace. -->
        <NavigationView
            x:Name="SettingsNavigationView"
            Grid.Row="1"
            Grid.RowSpan="2"
            Grid.ColumnSpan="2"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            AlwaysShowHeader="False"
            CompactPaneLength="{x:Bind SettingsNavigationCompactPaneLength, Mode=OneWay}"
            OpenPaneLength="{x:Bind SettingsNavigationOpenPaneLength, Mode=OneWay}"
            PaneDisplayMode="Left"
            SelectionChanged="SettingsNavigationView_SelectionChanged"
            Visibility="{x:Bind SettingsShellVisibility, Mode=OneWay}">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="{Binding Source={StaticResource Strings}, Path=[SettingsNavBack]}" Tag="Back">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource Strings}, Path=[SettingsSectionGeneral]}" Tag="General">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource Strings}, Path=[SettingsSectionAppearance]}" Tag="Appearance">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE790;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource Strings}, Path=[SettingsSectionFilesAndFolders]}" Tag="FilesAndFolders">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource Strings}, Path=[SettingsSectionShortcuts]}" Tag="Shortcuts">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE765;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource Strings}, Path=[SettingsSectionTags]}" Tag="Tags">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8EC;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource Strings}, Path=[SettingsSectionAdvanced]}" Tag="Advanced">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9CE;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource Strings}, Path=[SettingsSectionAbout]}" Tag="About">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Border
                x:Name="SettingsContentHostBorder"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderThickness="0"
                CornerRadius="{ThemeResource OverlayCornerRadius}">
                <controls:SettingsView x:Name="SettingsViewControl" />
            </Border>
        </NavigationView>
    </Grid>
</Window>
