<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FileExplorerUI.MainWindow"
    x:Name="RootWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileExplorerUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NorthFile">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        RowDefinitions="Auto,*"
        RowSpacing="8"
        Padding="8,8,8,0">
        <Grid
            ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,280"
            Height="36"
            ColumnSpacing="8">
            <Button
                x:Name="BackButton"
                Width="32"
                Height="32"
                Padding="0"
                Style="{ThemeResource SubtleButtonStyle}"
                Click="BackButton_Click"
                ToolTipService.ToolTip="Back">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE72B;" />
            </Button>

            <Button
                x:Name="ForwardButton"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                Style="{ThemeResource SubtleButtonStyle}"
                Click="ForwardButton_Click"
                ToolTipService.ToolTip="Forward">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE72A;" />
            </Button>

            <Button
                x:Name="UpButton"
                Grid.Column="2"
                Width="32"
                Height="32"
                Padding="0"
                Style="{ThemeResource SubtleButtonStyle}"
                Click="UpButton_Click"
                ToolTipService.ToolTip="Up">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE74A;" />
            </Button>

            <Button
                x:Name="LoadButton"
                Grid.Column="3"
                Width="32"
                Height="32"
                Padding="0"
                Style="{ThemeResource SubtleButtonStyle}"
                Click="LoadButton_Click"
                ToolTipService.ToolTip="Go">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE72C;" />
            </Button>

            <Button
                x:Name="NewFileButton"
                Grid.Column="4"
                Width="32"
                Height="32"
                Padding="0"
                Style="{ThemeResource SubtleButtonStyle}"
                Click="NewFileButton_Click"
                ToolTipService.ToolTip="New file">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE7C3;" />
            </Button>

            <Button
                x:Name="NewFolderButton"
                Grid.Column="5"
                Width="32"
                Height="32"
                Padding="0"
                Style="{ThemeResource SubtleButtonStyle}"
                Click="NewFolderButton_Click"
                ToolTipService.ToolTip="New folder">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE8B7;" />
            </Button>

            <Button
                x:Name="CopyButton"
                Grid.Column="6"
                Width="32"
                Height="32"
                Padding="0"
                Style="{ThemeResource SubtleButtonStyle}"
                Click="CopyButton_Click"
                ToolTipService.ToolTip="Copy">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE8C8;" />
            </Button>

            <Button
                x:Name="CutButton"
                Grid.Column="7"
                Width="32"
                Height="32"
                Padding="0"
                Style="{ThemeResource SubtleButtonStyle}"
                Click="CutButton_Click"
                ToolTipService.ToolTip="Cut">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE8C6;" />
            </Button>

            <Button
                x:Name="PasteButton"
                Grid.Column="8"
                Width="32"
                Height="32"
                Padding="0"
                Style="{ThemeResource SubtleButtonStyle}"
                Click="PasteButton_Click"
                ToolTipService.ToolTip="Paste">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE77F;" />
            </Button>

            <Grid Grid.Column="9">
                <Border
                    x:Name="AddressBreadcrumbBorder"
                    Height="32"
                    Padding="6,0,72,0"
                    Background="{ThemeResource TextControlBackground}"
                    BorderBrush="{ThemeResource TextControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    SizeChanged="AddressBreadcrumbBorder_SizeChanged"
                    Tapped="AddressBreadcrumbBorder_Tapped">
                    <Grid
                        ColumnDefinitions="Auto,*"
                        VerticalAlignment="Center">
                        <Button
                            x:Name="OverflowBreadcrumbButton"
                            Grid.Column="0"
                            Padding="6,0,6,1"
                            Margin="0,0,4,0"
                            Style="{ThemeResource SubtleButtonStyle}"
                            Visibility="Collapsed"
                            Click="OverflowBreadcrumbButton_Click"
                            ToolTipService.ToolTip="Show hidden path parts">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="12"
                                Glyph="&#xE712;" />
                        </Button>
                        <ItemsControl
                            x:Name="BreadcrumbMeasureItemsControl"
                            Grid.Column="1"
                            Opacity="0"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding Breadcrumbs, ElementName=RootWindow}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:BreadcrumbItemViewModel">
                                    <Grid
                                        ColumnDefinitions="Auto,Auto"
                                        Loaded="MeasureBreadcrumbItem_Loaded"
                                        SizeChanged="MeasureBreadcrumbItem_SizeChanged">
                                        <Button Padding="10,0,10,1" IsHitTestVisible="False">
                                            <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                        </Button>
                                        <Button
                                            Grid.Column="1"
                                            Padding="4,4,4,4"
                                            Visibility="{Binding ChevronVisibility}"
                                            IsHitTestVisible="False">
                                            <Button.Content>
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="12"
                                                    Glyph="&#xE76C;" />
                                            </Button.Content>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl
                            x:Name="BreadcrumbItemsControl"
                            Grid.Column="1"
                            Opacity="0"
                            ItemsSource="{Binding VisibleBreadcrumbs, ElementName=RootWindow}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:BreadcrumbItemViewModel">
                                    <Grid ColumnDefinitions="Auto,Auto">
                                        <Button
                                            Padding="10,0,10,1"
                                            Style="{ThemeResource SubtleButtonStyle}"
                                            Click="BreadcrumbButton_Click"
                                            Tag="{Binding FullPath}">
                                            <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                        </Button>
                                        <Button
                                            Grid.Column="1"
                                            Padding="4,4,4,4"
                                            Style="{ThemeResource SubtleButtonStyle}"
                                            Visibility="{Binding ChevronVisibility}"
                                            Click="BreadcrumbChevronButton_Click"
                                            Tag="{Binding FullPath}">
                                            <Button.Content>
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="12"
                                                    Glyph="&#xE76C;" />
                                            </Button.Content>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <TextBox
                    x:Name="PathTextBox"
                    Padding="12,7,36,8"
                    PlaceholderText="Address"
                    Text="C:\"
                    Visibility="Collapsed"
                    KeyDown="PathTextBox_KeyDown"
                    LostFocus="PathTextBox_LostFocus" />
            </Grid>

            <TextBox
                x:Name="SearchTextBox"
                Grid.Column="10"
                Height="32"
                PlaceholderText="Search in current folder"
                KeyDown="SearchTextBox_KeyDown" />
        </Grid>

        <Grid
            x:Name="ExplorerShellGrid"
            Grid.Row="1"
            ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{x:Bind SidebarColumnWidth, Mode=OneWay}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="Transparent">
                <Grid>
                    <local:SidebarView x:Name="StyledSidebarView" />
                    <NavigationView
                        x:Name="SidebarNavView"
                        Visibility="Collapsed"
                        IsEnabled="False"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        AlwaysShowHeader="False"
                        CompactPaneLength="32"
                        OpenPaneLength="220"
                        PaneDisplayMode="Left"
                        SelectionChanged="SidebarNavView_SelectionChanged" />
                </Grid>
            </Border>

            <Grid
                Grid.Column="1"
                RowDefinitions="*,Auto"
                Padding="0">
                <Grid
                    x:Name="ExplorerBodyGrid"
                    Grid.Row="0"
                    Padding="0">
                <Border
                    Padding="4,8,0,8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Grid RowDefinitions="Auto,*">
                        <Border
                            x:Name="DetailsHeaderBorder"
                            Width="{x:Bind DetailsRowWidth, Mode=OneWay}"
                            Margin="0"
                            Padding="8,0,8,0"
                            HorizontalAlignment="Left"
                            Background="Transparent">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="DetailsHeaderTranslateTransform" />
                            </Border.RenderTransform>
                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                <Grid x:Name="DetailsHeaderGrid" Height="28" Margin="0" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=NameColumnWidth}" MinWidth="120" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=TypeColumnWidth}" MinWidth="90" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=SizeColumnWidth}" MinWidth="80" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=ModifiedColumnWidth}" MinWidth="120" />
                                        <ColumnDefinition Width="6" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Padding="32,0,0,0" Background="Transparent">
                                        <TextBlock
                                            x:Name="NameHeaderTextBlock"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Opacity="0.72"
                                            Text="名称" />
                                    </Border>
                                    <TextBlock
                                        x:Name="TypeHeaderTextBlock"
                                        Grid.Column="2"
                                        Margin="8,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Opacity="0.72"
                                        Text="类型" />
                                    <TextBlock
                                        x:Name="SizeHeaderTextBlock"
                                        Grid.Column="4"
                                        Margin="8,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Opacity="0.72"
                                        Text="大小" />
                                    <TextBlock
                                        x:Name="ModifiedHeaderTextBlock"
                                        Grid.Column="6"
                                        Margin="8,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Opacity="0.72"
                                        Text="修改日期" />

                                    <local:ColumnSplitter
                                        x:Name="HeaderSplitter1"
                                        Grid.Column="1"
                                        Tag="1"
                                        PointerEntered="ColumnSplitterHover_PointerEntered"
                                        PointerExited="ColumnSplitterHover_PointerExited" />
                                    <local:ColumnSplitter
                                        x:Name="HeaderSplitter2"
                                        Grid.Column="3"
                                        Tag="2"
                                        PointerEntered="ColumnSplitterHover_PointerEntered"
                                        PointerExited="ColumnSplitterHover_PointerExited" />
                                    <local:ColumnSplitter
                                        x:Name="HeaderSplitter3"
                                        Grid.Column="5"
                                        Tag="3"
                                        PointerEntered="ColumnSplitterHover_PointerEntered"
                                        PointerExited="ColumnSplitterHover_PointerExited" />
                                    <local:ColumnSplitter
                                        x:Name="HeaderSplitter4"
                                        Grid.Column="7"
                                        Tag="4"
                                        PointerEntered="ColumnSplitterHover_PointerEntered"
                                        PointerExited="ColumnSplitterHover_PointerExited" />
                                </Grid>
                            </Border>
                        </Border>

                        <ListView
                            x:Name="EntriesListView"
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            DoubleTapped="EntriesListView_DoubleTapped"
                            ContextRequested="EntriesListView_ContextRequested"
                            ItemContainerTransitions="{x:Null}"
                            IsItemClickEnabled="False"
                            Loaded="EntriesListView_Loaded"
                            Padding="0"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollMode="Enabled"
                            ScrollViewer.VerticalScrollBarVisibility="Visible"
                            ScrollViewer.VerticalScrollMode="Enabled"
                            SelectionChanged="EntriesListView_SelectionChanged"
                            SelectionMode="Single">
                            <ListView.ItemContainerStyle>
                                <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                    <Setter Property="Width" Value="{Binding ElementName=RootWindow, Path=DetailsRowWidth}" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Height" Value="30" />
                                    <Setter Property="MinHeight" Value="30" />
                                    <Setter Property="CornerRadius" Value="0" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ContextFlyout>
                                <MenuFlyout
                                    x:Name="EntriesContextFlyout"
                                    Opening="EntriesContextFlyout_Opening"
                                    Closed="EntriesContextFlyout_Closed">
                                    <MenuFlyoutItem Click="ContextNewFile_Click" Text="New File" />
                                    <MenuFlyoutItem Click="ContextNewFolder_Click" Text="New Folder" />
                                    <MenuFlyoutSeparator x:Name="ContextCreateSeparator" />
                                    <MenuFlyoutItem x:Name="ContextCopyMenuItem" Click="ContextCopy_Click" Text="Copy" />
                                    <MenuFlyoutItem x:Name="ContextCutMenuItem" Click="ContextCut_Click" Text="Cut" />
                                    <MenuFlyoutItem x:Name="ContextPasteMenuItem" Click="ContextPaste_Click" Text="Paste" />
                                    <MenuFlyoutSeparator x:Name="ContextClipboardSeparator" />
                                    <MenuFlyoutItem x:Name="ContextRenameMenuItem" Click="ContextRename_Click" Text="Rename" />
                                    <MenuFlyoutItem x:Name="ContextDeleteMenuItem" Click="ContextDelete_Click" Text="Delete" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Click="ContextRefresh_Click" Text="Refresh" />
                                </MenuFlyout>
                            </ListView.ContextFlyout>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Height="30"
                                        Padding="8,0,8,0"
                                        HorizontalAlignment="Stretch"
                                        PointerPressed="EntryRow_PointerPressed"
                                        RightTapped="EntryRow_RightTapped">
                                        <Grid HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=NameColumnWidth}" MinWidth="120" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=TypeColumnWidth}" MinWidth="90" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=SizeColumnWidth}" MinWidth="80" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=ModifiedColumnWidth}" MinWidth="120" />
                                                <ColumnDefinition Width="6" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" Margin="6,0,0,0" VerticalAlignment="Center" ColumnDefinitions="18,8,*">
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Width="18"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="14"
                                                    Foreground="{Binding IconForeground}"
                                                    Text="{Binding IconGlyph}" />
                                                <TextBlock
                                                    x:Name="EntryNameTextBlock"
                                                    Grid.Column="2"
                                                    Margin="0,0,4,0"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding Name}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                            <TextBlock
                                                Grid.Column="2"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Type}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding SizeText}" />
                                            <TextBlock
                                                Grid.Column="6"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding ModifiedText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Canvas x:Name="RenameOverlayCanvas" Grid.Row="1" Margin="0,8,0,0">
                            <Border
                                x:Name="RenameOverlayBorder"
                                Width="160"
                                Height="24"
                                Background="White"
                                BorderBrush="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                                BorderThickness="1"
                                Padding="1,0,0,1"
                                CornerRadius="0"
                                Visibility="Collapsed">
                                <TextBox
                                    x:Name="RenameOverlayTextBox"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    FontSize="14"
                                    HorizontalContentAlignment="Left"
                                    KeyDown="RenameOverlayTextBox_KeyDown"
                                    LostFocus="RenameOverlayTextBox_LostFocus"
                                    MinHeight="24"
                                    Padding="0"
                                    TextAlignment="Left"
                                    Margin="0,-1,0,0"
                                    VerticalContentAlignment="Center">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="TextBox">
                                            <Grid>
                                                <Border
                                                    x:Name="BorderElement"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    Control.IsTemplateFocusTarget="True" />
                                                <ScrollViewer
                                                    x:Name="ContentElement"
                                                    AutomationProperties.AccessibilityView="Raw"
                                                    Foreground="{TemplateBinding Foreground}"
                                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                    HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                    HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                                    IsDeferredScrollingEnabled="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                                                    IsHorizontalRailEnabled="{TemplateBinding ScrollViewer.IsHorizontalRailEnabled}"
                                                    IsTabStop="False"
                                                    IsVerticalRailEnabled="{TemplateBinding ScrollViewer.IsVerticalRailEnabled}"
                                                    Margin="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}"
                                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                    VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                                    VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                                    ZoomMode="Disabled" />
                                            </Grid>
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>
                            </Border>
                        </Canvas>
                    </Grid>
                </Border>

                <Border
                    x:Name="CommandDockPanel"
                    Width="360"
                    Margin="10"
                    Padding="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    PointerExited="CommandDockPanel_PointerExited"
                    Visibility="Collapsed">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Command Dock" />
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Button x:Name="RenameButton" Grid.Column="0" Click="RenameButton_Click" Content="Rename" />
                            <Button x:Name="DeleteButton" Grid.Column="1" Click="DeleteButton_Click" Content="Delete" />
                            <Button x:Name="NextButton" Grid.Column="2" Click="NextButton_Click" Content="Load More" />
                        </Grid>
                        <TextBox x:Name="RenameTextBox" PlaceholderText="new name" />
                        <CheckBox x:Name="RecursiveDeleteCheckBox" Content="Recursive delete" />

                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8">
                            <RadioButton
                                GroupName="DockSide"
                                Tag="Top"
                                Checked="DockRadio_Checked"
                                Content="Top"
                                IsChecked="True" />
                            <RadioButton
                                Grid.Column="1"
                                GroupName="DockSide"
                                Tag="Right"
                                Checked="DockRadio_Checked"
                                Content="Right" />
                            <RadioButton
                                Grid.Column="2"
                                GroupName="DockSide"
                                Tag="Bottom"
                                Checked="DockRadio_Checked"
                                Content="Bottom" />
                            <ToggleSwitch
                                x:Name="CommandAutoHideSwitch"
                                Grid.Column="3"
                                Header="Auto hide"
                                HorizontalAlignment="Right"
                                Toggled="CommandAutoHideSwitch_Toggled" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Button
                    x:Name="CommandPeekButton"
                    Margin="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Click="CommandPeekButton_Click"
                    Content="Commands"
                    Visibility="Collapsed" />
                </Grid>

                <Grid Grid.Row="1" Height="32">
                    <TextBlock
                        x:Name="StatusTextBlock"
                        Margin="18,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        LineHeight="11"
                        LineStackingStrategy="BlockLineHeight"
                        Text="加载中..."
                        TextWrapping="Wrap" />
                </Grid>
            </Grid>

            <local:ColumnSplitter
                x:Name="SidebarSplitter"
                Grid.Column="1"
                Width="8"
                Margin="-4,0,0,0"
                HorizontalAlignment="Left"
                ShowGuide="False"
                VerticalAlignment="Stretch"
                PointerEntered="ColumnSplitterHover_PointerEntered"
                PointerExited="ColumnSplitterHover_PointerExited" />
        </Grid>
    </Grid>
</Window>
