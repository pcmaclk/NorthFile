<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FileExplorerUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileExplorerUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NorthFile">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RowDefinitions="Auto,*" RowSpacing="8" Padding="8">
        <Grid
            ColumnDefinitions="Auto,Auto,Auto,Auto,*,280"
            Height="36"
            ColumnSpacing="8">
            <Button
                x:Name="BackButton"
                Width="32"
                Height="32"
                Padding="0"
                IsEnabled="False"
                ToolTipService.ToolTip="Back">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE72B;" />
            </Button>

            <Button
                x:Name="ForwardButton"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                IsEnabled="False"
                ToolTipService.ToolTip="Forward">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE72A;" />
            </Button>

            <Button
                x:Name="UpButton"
                Grid.Column="2"
                Width="32"
                Height="32"
                Padding="0"
                IsEnabled="False"
                ToolTipService.ToolTip="Up">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE74A;" />
            </Button>

            <Button
                x:Name="LoadButton"
                Grid.Column="3"
                Width="32"
                Height="32"
                Padding="0"
                IsEnabled="False"
                ToolTipService.ToolTip="Go">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE72C;" />
            </Button>

            <TextBox
                x:Name="PathTextBox"
                Grid.Column="4"
                VerticalAlignment="Stretch"
                Header="地址"
                Text="C:\Users\Demo\Documents"
                PlaceholderText="输入模拟路径"
                IsReadOnly="True" />

            <TextBox
                x:Name="SearchTextBox"
                Grid.Column="5"
                VerticalAlignment="Stretch"
                Header="搜索"
                PlaceholderText="先保留样式，不做搜索" />
        </Grid>

        <NavigationView
            x:Name="SidebarNavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            AlwaysShowHeader="False"
            PaneDisplayMode="Left"
            CompactPaneLength="48"
            OpenPaneLength="280">
            <NavigationView.PaneCustomContent>
                <local:SidebarView />
            </NavigationView.PaneCustomContent>

            <Frame x:Name="ContentFrame">
                <Grid Padding="24">
                    <Border
                        Padding="24"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="12">
                            <TextBlock
                                Text="Mock Shell"
                                Opacity="0.72" />
                            <TextBlock
                                Text="右侧内容区域"
                                Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock
                                Text="当前阶段只保留界面壳子：顶部地址栏、左侧 NavigationView、固定区域和文件树。"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Frame>
        </NavigationView>
    </Grid>
</Window>
