<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FileExplorerUI.MainWindow"
    x:Name="RootWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileExplorerUI"
    xmlns:controls="using:FileExplorerUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NorthFile">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="WindowRootGrid"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="0"
        Padding="{x:Bind ShellWindowPadding, Mode=OneWay}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{x:Bind SidebarColumnWidth, Mode=OneWay}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid
            x:Name="LeftShellColumn"
            Grid.Column="0"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            RowDefinitions="Auto,*">
            <!-- Left-side title bar chrome for explorer mode: collapse/settings live above the sidebar. -->
            <Grid
                Height="{x:Bind ShellTitleBarHeight, Mode=OneWay}"
                Visibility="{x:Bind SidebarTopChromeVisibility, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Orientation="Horizontal"
                    Padding="4, 0, 0, 0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Spacing="4">
                    <Button
                        x:Name="SidebarCollapseButton"
                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                        Padding="0"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Click="SidebarCollapseButton_Click">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind SidebarCollapseButtonToolTipText, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                            Glyph="&#xE700;" />
                    </Button>

                    <Button
                        x:Name="SidebarTopSettingsButton"
                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                        Padding="0"
                        Visibility="{x:Bind SidebarTopSettingsVisibility, Mode=OneWay}"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Click="TitleBarSettingsButton_Click">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{Binding Source={StaticResource Strings}, Path=[SidebarSettingsButtonToolTip.Content]}" />
                        </ToolTipService.ToolTip>
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                            Glyph="&#xE713;" />
                    </Button>

                    <Button
                        x:Name="LanguageToggleButton"
                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                        Padding="0"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Click="LanguageToggleButton_Click"
                        UseSystemFocusVisuals="False">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{Binding Source={StaticResource Strings}, Path=[ToolTipToggleTheme]}" />
                        </ToolTipService.ToolTip>
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                            Glyph="{x:Bind ThemeToggleGlyph, Mode=OneWay}" />
                    </Button>
                </StackPanel>
                <Grid
                    x:Name="LeftTitleBarDragRegion"
                    Grid.Column="1"
                    Background="Transparent"
                    Loaded="TitleBarDragRegion_Loaded"
                    SizeChanged="TitleBarDragRegion_SizeChanged" />
            </Grid>

            <!-- Explorer sidebar host occupies the left shell column. -->
            <Grid
                Grid.Row="1"
                Padding="{x:Bind SidebarContentPadding, Mode=OneWay}"
                HorizontalAlignment="Stretch"
                Background="Transparent"
                Visibility="{x:Bind ExplorerShellVisibility, Mode=OneWay}">
                <local:SidebarView x:Name="StyledSidebarView" />
            </Grid>
        </Grid>

        <Grid
            x:Name="RightShellColumn"
            Grid.Column="1"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            RowDefinitions="Auto,Auto,*">
            <Grid.Resources>
                <ResourceDictionary Source="Resources/MainWindowResources.xaml" />
            </Grid.Resources>
        <!-- Right-side title bar shell: tab strip stays aligned to the content column. -->
        <TabView
            x:Name="SingleTabTitleBarView"
            Height="{x:Bind ShellTitleBarHeight, Mode=OneWay}"
            Margin="{x:Bind ShellTitleBarMargin, Mode=OneWay}"
            HorizontalAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0"
            CanDragTabs="False"
            IsAddTabButtonVisible="False"
            IsTabStop="False"
            SelectionChanged="SingleTabTitleBarView_SelectionChanged"
            TabWidthMode="Equal">
            <TabView.Resources>
                <ResourceDictionary Source="Resources/MainWindowTabResources.xaml" />
            </TabView.Resources>
            <TabView.TabStripHeader>
                <Grid
                    x:Name="WindowTabStripLeftInset"
                    Width="{x:Bind ShellTitleBarLeftInsetWidth, Mode=OneWay}"
                    Visibility="{x:Bind ShellTitleBarLeftInsetVisibility, Mode=OneWay}"
                    Background="Transparent">
                    <Button
                        x:Name="TitleBarSettingsButton"
                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                        Margin="{x:Bind ShellTitleBarLeftInsetButtonMargin, Mode=OneWay}"
                        Padding="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Visibility="{x:Bind TitleBarSidebarSettingsVisibility, Mode=OneWay}"
                        Click="TitleBarSettingsButton_Click">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{Binding Source={StaticResource Strings}, Path=[SidebarSettingsButtonToolTip.Content]}" />
                        </ToolTipService.ToolTip>
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                            Glyph="&#xE713;" />
                    </Button>
                </Grid>
            </TabView.TabStripHeader>
            <TabView.TabStripFooter>
                <Grid ColumnDefinitions="Auto,*">
                    <Button
                        x:Name="AddWorkspaceTabButton"
                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                        Padding="0"
                        Margin="{x:Bind AddWorkspaceTabButtonMargin, Mode=OneWay}"
                        VerticalAlignment="Top"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Visibility="{x:Bind ExplorerShellVisibility, Mode=OneWay}"
                        Click="AddWorkspaceTabButton_Click">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="新建标签页" />
                        </ToolTipService.ToolTip>
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                            Glyph="&#xE710;" />
                    </Button>
                    <Grid
                        x:Name="WindowTabDragRegion"
                        Grid.Column="1"
                        MinWidth="188"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        Loaded="TitleBarDragRegion_Loaded"
                        SizeChanged="TitleBarDragRegion_SizeChanged" />
                </Grid>
            </TabView.TabStripFooter>
        </TabView>

        <!-- Explorer toolbar stays separate from pane bodies to keep startup stable while dual-pane stays shell-only. -->
        <Grid
            x:Name="ExplorerToolbarHost"
            Grid.Row="1"
            Margin="{x:Bind ShellToolbarMargin, Mode=OneWay}"
            Visibility="{x:Bind ExplorerChromeVisibility, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="PrimaryToolbarPaneColumn" Width="{x:Bind ExplorerPanePrimaryColumnWidth, Mode=OneWay}" />
                <ColumnDefinition x:Name="ToolbarActionRailColumn" Width="{x:Bind ExplorerPaneToolbarActionRailColumnWidth, Mode=OneWay}" />
                <ColumnDefinition x:Name="SecondaryToolbarPaneColumn" Width="{x:Bind ExplorerPaneSecondaryColumnWidth, Mode=OneWay}" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <controls:ExplorerPaneNavigationBar
                    x:Name="PrimaryToolbarPaneHost"
                    PointerPressed="PrimaryPaneSurface_PointerPressed"
                    ChromePadding="{x:Bind ShellToolbarPadding, Mode=OneWay}"
                    ChromeBackground="{x:Bind PrimaryPaneToolbarBackground, Mode=OneWay}"
                    ChromeBorderBrush="{x:Bind PrimaryPaneToolbarBorderBrush, Mode=OneWay}"
                    ChromeBorderThickness="{x:Bind PrimaryPaneToolbarBorderThickness, Mode=OneWay}"
                    ChromeTranslation="{x:Bind PrimaryPaneToolbarTranslation, Mode=OneWay}"
                    LayoutHeight="{x:Bind ShellControlSize, Mode=OneWay}"
                    ColumnSpacing="8">
                    <controls:ExplorerPaneNavigationBar.LeadingContent>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button
                                        x:Name="BackButton"
                                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Padding="0"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Click="BackButton_Click">
                                        <ToolTipService.ToolTip>
                                            <ToolTip x:Uid="BackButtonToolTip" />
                                        </ToolTipService.ToolTip>
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                                            Glyph="&#xE72B;" />
                                    </Button>
                                    <Button
                                        x:Name="ForwardButton"
                                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Padding="0"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Click="ForwardButton_Click">
                                        <ToolTipService.ToolTip>
                                            <ToolTip x:Uid="ForwardButtonToolTip" />
                                        </ToolTipService.ToolTip>
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                                            Glyph="&#xE72A;" />
                                    </Button>
                                    <Button
                                        x:Name="UpButton"
                                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Padding="0"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Click="UpButton_Click">
                                        <ToolTipService.ToolTip>
                                            <ToolTip x:Uid="UpButtonToolTip" />
                                        </ToolTipService.ToolTip>
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                                            Glyph="&#xE74A;" />
                                    </Button>
                                    <Button
                                        x:Name="LoadButton"
                                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Padding="0"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Click="LoadButton_Click">
                                        <ToolTipService.ToolTip>
                                            <ToolTip x:Uid="LoadButtonToolTip" />
                                        </ToolTipService.ToolTip>
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                                            Glyph="&#xE72C;" />
                                    </Button>
                                    <Button
                                        x:Name="PrimaryPaneCloseButton"
                                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Padding="0"
                                        Visibility="{x:Bind ExplorerSecondaryPaneVisibility, Mode=OneWay}"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Click="PrimaryPaneCloseButton_Click">
                                        <ToolTipService.ToolTip>
                                            <ToolTip Content="关闭此面板" />
                                        </ToolTipService.ToolTip>
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                                            Glyph="&#xE711;" />
                                    </Button>
                                </StackPanel>
                    </controls:ExplorerPaneNavigationBar.LeadingContent>
                    <controls:ExplorerPaneNavigationBar.AddressContent>
                                <Grid>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="PrimaryAddressChromeStates">
                                            <VisualState x:Name="PrimaryAddressChromeInactive" />
                                            <VisualState x:Name="PrimaryAddressChromeActive">
                                                <VisualState.StateTriggers>
                                                    <controls:BoolStateTrigger Value="{x:Bind IsPrimaryWorkspacePanelActive, Mode=OneWay}" />
                                                </VisualState.StateTriggers>
                                                <VisualState.Setters>
                                                    <Setter Target="AddressBreadcrumbBorder.Background" Value="{ThemeResource ActivePaneInputBackgroundBrush}" />
                                                    <Setter Target="AddressBreadcrumbBorder.BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                                    <Setter Target="PathTextBox.Background" Value="{ThemeResource ActivePaneInputBackgroundBrush}" />
                                                    <Setter Target="PathTextBox.BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                                    <Setter Target="PathTextBox.Foreground" Value="{ThemeResource ActivePaneForegroundBrush}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <Border
                                        x:Name="AddressBreadcrumbBorder"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Style="{StaticResource PaneAddressBreadcrumbBorderStyle}"
                                        SizeChanged="AddressBreadcrumbBorder_SizeChanged"
                                        Tapped="AddressBreadcrumbBorder_Tapped">
                                        <Grid
                                            ColumnDefinitions="Auto,*,40"
                                            VerticalAlignment="Center">
                                            <Button
                                                x:Name="OverflowBreadcrumbButton"
                                                Grid.Column="0"
                                                Style="{StaticResource PaneOverflowBreadcrumbButtonStyle}"
                                                Visibility="Collapsed"
                                                Click="OverflowBreadcrumbButton_Click">
                                                <ToolTipService.ToolTip>
                                                    <ToolTip x:Uid="OverflowBreadcrumbButtonToolTip" />
                                                </ToolTipService.ToolTip>
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="12"
                                                    Glyph="&#xE712;" />
                                            </Button>
                                            <ItemsControl
                                                x:Name="BreadcrumbMeasureItemsControl"
                                                Grid.Column="1"
                                                Opacity="0"
                                                IsHitTestVisible="False"
                                                HorizontalAlignment="Left"
                                                ItemsSource="{x:Bind Breadcrumbs, Mode=OneWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="2" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="local:BreadcrumbItemViewModel">
                                                        <Grid
                                                            ColumnDefinitions="Auto,Auto"
                                                            Loaded="MeasureBreadcrumbItem_Loaded"
                                                            SizeChanged="MeasureBreadcrumbItem_SizeChanged">
                                                            <Button
                                                                Style="{StaticResource PaneBreadcrumbButtonStyle}"
                                                                IsHitTestVisible="False">
                                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                                    <FontIcon
                                                                        FontFamily="Segoe Fluent Icons"
                                                                        FontSize="12"
                                                                        Glyph="{Binding IconGlyph}"
                                                                        Visibility="{Binding IconVisibility}" />
                                                                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button
                                                                Grid.Column="1"
                                                                Style="{StaticResource PaneBreadcrumbChevronButtonStyle}"
                                                                Visibility="{Binding ChevronVisibility}"
                                                                IsHitTestVisible="False">
                                                                <Button.Content>
                                                                    <FontIcon
                                                                        FontFamily="Segoe Fluent Icons"
                                                                        FontSize="12"
                                                                        Glyph="&#xE76C;" />
                                                                </Button.Content>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <ItemsControl
                                                x:Name="BreadcrumbItemsControl"
                                                Grid.Column="1"
                                                HorizontalAlignment="Left"
                                                ItemsSource="{x:Bind VisibleBreadcrumbs, Mode=OneWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="2" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="local:BreadcrumbItemViewModel">
                                                        <Grid ColumnDefinitions="Auto,Auto">
                                                            <Button
                                                                Style="{StaticResource PaneBreadcrumbButtonStyle}"
                                                                Tag="{Binding FullPath}"
                                                                Click="BreadcrumbButton_Click">
                                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                                    <FontIcon
                                                                        FontFamily="Segoe Fluent Icons"
                                                                        FontSize="12"
                                                                        Glyph="{Binding IconGlyph}"
                                                                        Visibility="{Binding IconVisibility}" />
                                                                    <TextBlock
                                                                        Text="{Binding Label}"
                                                                        TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button
                                                                Grid.Column="1"
                                                                Style="{StaticResource PaneBreadcrumbChevronButtonStyle}"
                                                                Tag="{Binding FullPath}"
                                                                Visibility="{Binding ChevronVisibility}"
                                                                Click="BreadcrumbChevronButton_Click">
                                                                <Button.Content>
                                                                    <FontIcon
                                                                        FontFamily="Segoe Fluent Icons"
                                                                        FontSize="12"
                                                                        Glyph="&#xE76C;" />
                                                                </Button.Content>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Visibility="{x:Bind AddressTextFallbackVisibility, Mode=OneWay}"
                                                Text="{x:Bind DisplayAddressText, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <Grid
                                                x:Name="PrimaryAddressEditHitTarget"
                                                Grid.Column="2"
                                                Background="Transparent" />
                                        </Grid>
                                    </Border>
                                    <TextBox
                                        x:Name="PathTextBox"
                                        x:Uid="PathTextBox"
                                        Style="{StaticResource PaneAddressTextBoxStyle}"
                                        GotFocus="PrimaryPaneInput_GotFocus"
                                        PointerPressed="PrimaryPaneInput_PointerPressed"
                                        TextChanging="PathTextBox_TextChanging"
                                        Text="C:\"
                                        Visibility="Collapsed"
                                        KeyDown="PathTextBox_KeyDown" />
                                    <TeachingTip
                                        x:Name="AddressInputTeachingTip"
                                        IsLightDismissEnabled="False"
                                        IsOpen="False"
                                        PlacementMargin="8"
                                        PreferredPlacement="Bottom" />
                                </Grid>
                    </controls:ExplorerPaneNavigationBar.AddressContent>
                    <controls:ExplorerPaneNavigationBar.SearchContent>
                                <Grid>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="PrimarySearchChromeStates">
                                            <VisualState x:Name="PrimarySearchChromeInactive" />
                                            <VisualState x:Name="PrimarySearchChromeActive">
                                                <VisualState.StateTriggers>
                                                    <controls:BoolStateTrigger Value="{x:Bind IsPrimaryWorkspacePanelActive, Mode=OneWay}" />
                                                </VisualState.StateTriggers>
                                                <VisualState.Setters>
                                                    <Setter Target="SearchTextBox.Background" Value="{ThemeResource ActivePaneInputBackgroundBrush}" />
                                                    <Setter Target="SearchTextBox.BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                                    <Setter Target="SearchTextBox.Foreground" Value="{ThemeResource ActivePaneForegroundBrush}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <TextBox
                                        x:Name="SearchTextBox"
                                        x:Uid="SearchTextBox"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Visibility="{x:Bind PrimaryPaneSearchVisibility, Mode=OneWay}"
                                        Style="{StaticResource PaneSearchTextBoxStyle}"
                                        GotFocus="PrimaryPaneInput_GotFocus"
                                        PointerPressed="PrimaryPaneInput_PointerPressed"
                                        TextChanged="SearchTextBox_TextChanged"
                                        KeyDown="SearchTextBox_KeyDown" />
                                </Grid>
                    </controls:ExplorerPaneNavigationBar.SearchContent>
                </controls:ExplorerPaneNavigationBar>
            </Grid>

            <Grid
                x:Name="ExplorerPaneActionToolbarHost"
                Grid.Column="1"
                Visibility="{x:Bind ExplorerPaneToolbarActionRailVisibility, Mode=OneWay}">
                <Button
                    x:Name="ExplorerPaneToggleButton"
                    Width="{x:Bind ShellControlSize, Mode=OneWay}"
                    Height="{x:Bind ShellControlSize, Mode=OneWay}"
                    Padding="0"
                    Margin="{x:Bind ExplorerPaneToggleButtonMargin, Mode=OneWay}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Style="{ThemeResource SubtleButtonStyle}"
                    Click="ExplorerPaneToggleButton_Click">
                    <ToolTipService.ToolTip>
                        <ToolTip Content="{x:Bind ExplorerPaneToggleToolTipText, Mode=OneWay}" />
                    </ToolTipService.ToolTip>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                        Glyph="{x:Bind ExplorerPaneToggleGlyph, Mode=OneWay}" />
                </Button>
            </Grid>

            <Grid
                Grid.Column="2"
                Visibility="{x:Bind ExplorerSecondaryPaneVisibility, Mode=OneWay}">
                <controls:ExplorerPaneNavigationBar
                    x:Name="SecondaryToolbarPaneHost"
                    PointerPressed="SecondaryPaneSurface_PointerPressed"
                    ChromePadding="{x:Bind ShellToolbarPadding, Mode=OneWay}"
                    ChromeBackground="{x:Bind SecondaryPaneToolbarBackground, Mode=OneWay}"
                    ChromeBorderBrush="{x:Bind SecondaryPaneToolbarBorderBrush, Mode=OneWay}"
                    ChromeBorderThickness="{x:Bind SecondaryPaneToolbarBorderThickness, Mode=OneWay}"
                    ChromeTranslation="{x:Bind SecondaryPaneToolbarTranslation, Mode=OneWay}"
                    LayoutHeight="{x:Bind ShellControlSize, Mode=OneWay}"
                    ColumnSpacing="8">
                    <controls:ExplorerPaneNavigationBar.LeadingContent>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button
                                        x:Name="SecondaryPaneBackButton"
                                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Padding="0"
                                        IsEnabled="{x:Bind SecondaryPaneCanGoBack, Mode=OneWay}"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Click="SecondaryPaneBackButton_Click">
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                                            Glyph="&#xE72B;" />
                                    </Button>
                                    <Button
                                        x:Name="SecondaryPaneForwardButton"
                                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Padding="0"
                                        IsEnabled="{x:Bind SecondaryPaneCanGoForward, Mode=OneWay}"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Click="SecondaryPaneForwardButton_Click">
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                                            Glyph="&#xE72A;" />
                                    </Button>
                                    <Button
                                        x:Name="SecondaryPaneUpButton"
                                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Padding="0"
                                        IsEnabled="{x:Bind SecondaryPaneCanGoUp, Mode=OneWay}"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Click="SecondaryPaneUpButton_Click">
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                                            Glyph="&#xE74A;" />
                                    </Button>
                                    <Button
                                        x:Name="SecondaryPaneLoadButton"
                                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Padding="0"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Click="SecondaryPaneLoadButton_Click">
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                                            Glyph="&#xE72C;" />
                                    </Button>
                                    <Button
                                        x:Name="SecondaryPaneCloseButton"
                                        Width="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Padding="0"
                                        Visibility="{x:Bind ExplorerSecondaryPaneVisibility, Mode=OneWay}"
                                        Style="{ThemeResource SubtleButtonStyle}"
                                        Click="SecondaryPaneCloseButton_Click">
                                        <ToolTipService.ToolTip>
                                            <ToolTip Content="关闭此面板" />
                                        </ToolTipService.ToolTip>
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{x:Bind ShellGlyphSize, Mode=OneWay}"
                                            Glyph="&#xE711;" />
                                    </Button>
                                </StackPanel>
                    </controls:ExplorerPaneNavigationBar.LeadingContent>
                    <controls:ExplorerPaneNavigationBar.AddressContent>
                                <Grid>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="SecondaryAddressChromeStates">
                                            <VisualState x:Name="SecondaryAddressChromeInactive" />
                                            <VisualState x:Name="SecondaryAddressChromeActive">
                                                <VisualState.StateTriggers>
                                                    <controls:BoolStateTrigger Value="{x:Bind IsSecondaryWorkspacePanelActive, Mode=OneWay}" />
                                                </VisualState.StateTriggers>
                                                <VisualState.Setters>
                                                    <Setter Target="SecondaryAddressBreadcrumbBorder.Background" Value="{ThemeResource ActivePaneInputBackgroundBrush}" />
                                                    <Setter Target="SecondaryAddressBreadcrumbBorder.BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                                    <Setter Target="SecondaryPaneAddressTextBox.Background" Value="{ThemeResource ActivePaneInputBackgroundBrush}" />
                                                    <Setter Target="SecondaryPaneAddressTextBox.BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                                    <Setter Target="SecondaryPaneAddressTextBox.Foreground" Value="{ThemeResource ActivePaneForegroundBrush}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <Border
                                        x:Name="SecondaryAddressBreadcrumbBorder"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Style="{StaticResource PaneAddressBreadcrumbBorderStyle}"
                                        SizeChanged="SecondaryAddressBreadcrumbBorder_SizeChanged"
                                        Tapped="SecondaryAddressBreadcrumbBorder_Tapped">
                                        <Grid
                                            ColumnDefinitions="Auto,*,40"
                                            VerticalAlignment="Center">
                                            <Button
                                                x:Name="SecondaryOverflowBreadcrumbButton"
                                                Grid.Column="0"
                                                Style="{StaticResource PaneOverflowBreadcrumbButtonStyle}"
                                                Visibility="Collapsed"
                                                Click="SecondaryOverflowBreadcrumbButton_Click">
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="12"
                                                    Glyph="&#xE712;" />
                                            </Button>
                                            <ItemsControl
                                                x:Name="SecondaryBreadcrumbMeasureItemsControl"
                                                Grid.Column="1"
                                                Opacity="0"
                                                IsHitTestVisible="False"
                                                HorizontalAlignment="Left"
                                                ItemsSource="{x:Bind SecondaryPaneBreadcrumbs, Mode=OneWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="2" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="local:BreadcrumbItemViewModel">
                                                        <Grid
                                                            ColumnDefinitions="Auto,Auto"
                                                            Loaded="SecondaryMeasureBreadcrumbItem_Loaded"
                                                            SizeChanged="SecondaryMeasureBreadcrumbItem_SizeChanged">
                                                            <Button
                                                                Style="{StaticResource PaneBreadcrumbButtonStyle}"
                                                                IsHitTestVisible="False">
                                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                                    <FontIcon
                                                                        FontFamily="Segoe Fluent Icons"
                                                                        FontSize="12"
                                                                        Glyph="{Binding IconGlyph}"
                                                                        Visibility="{Binding IconVisibility}" />
                                                                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button
                                                                Grid.Column="1"
                                                                Style="{StaticResource PaneBreadcrumbChevronButtonStyle}"
                                                                Visibility="{Binding ChevronVisibility}"
                                                                IsHitTestVisible="False">
                                                                <Button.Content>
                                                                    <FontIcon
                                                                        FontFamily="Segoe Fluent Icons"
                                                                        FontSize="12"
                                                                        Glyph="&#xE76C;" />
                                                                </Button.Content>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <ItemsControl
                                                x:Name="SecondaryBreadcrumbItemsControl"
                                                Grid.Column="1"
                                                HorizontalAlignment="Left"
                                                ItemsSource="{x:Bind SecondaryPaneVisibleBreadcrumbs, Mode=OneWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="2" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="local:BreadcrumbItemViewModel">
                                                        <Grid ColumnDefinitions="Auto,Auto">
                                                            <Button
                                                                Style="{StaticResource PaneBreadcrumbButtonStyle}"
                                                                Tag="{Binding FullPath}"
                                                                Click="SecondaryBreadcrumbButton_Click">
                                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                                    <FontIcon
                                                                        FontFamily="Segoe Fluent Icons"
                                                                        FontSize="12"
                                                                        Glyph="{Binding IconGlyph}"
                                                                        Visibility="{Binding IconVisibility}" />
                                                                    <TextBlock
                                                                        Text="{Binding Label}"
                                                                        TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button
                                                                Grid.Column="1"
                                                                Style="{StaticResource PaneBreadcrumbChevronButtonStyle}"
                                                                Tag="{Binding FullPath}"
                                                                Visibility="{Binding ChevronVisibility}"
                                                                Click="SecondaryBreadcrumbChevronButton_Click">
                                                                <Button.Content>
                                                                    <FontIcon
                                                                        FontFamily="Segoe Fluent Icons"
                                                                        FontSize="12"
                                                                        Glyph="&#xE76C;" />
                                                                </Button.Content>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Visibility="{x:Bind SecondaryPaneAddressTextFallbackVisibility, Mode=OneWay}"
                                                Text="{x:Bind SecondaryPaneDisplayAddressText, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <Grid
                                                x:Name="SecondaryAddressEditHitTarget"
                                                Grid.Column="2"
                                                Background="Transparent" />
                                        </Grid>
                                    </Border>
                                    <TextBox
                                        x:Name="SecondaryPaneAddressTextBox"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Style="{StaticResource PaneAddressTextBoxStyle}"
                                        Text="{x:Bind SecondaryPaneAddressEditorText, Mode=TwoWay}"
                                        GotFocus="SecondaryPaneInput_GotFocus"
                                        PointerPressed="SecondaryPaneInput_PointerPressed"
                                        TextChanged="SecondaryPaneAddressTextBox_TextChanged"
                                        Visibility="Collapsed"
                                        KeyDown="SecondaryPaneAddressTextBox_KeyDown" />
                                </Grid>
                    </controls:ExplorerPaneNavigationBar.AddressContent>
                    <controls:ExplorerPaneNavigationBar.SearchContent>
                                <Grid>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="SecondarySearchChromeStates">
                                            <VisualState x:Name="SecondarySearchChromeInactive" />
                                            <VisualState x:Name="SecondarySearchChromeActive">
                                                <VisualState.StateTriggers>
                                                    <controls:BoolStateTrigger Value="{x:Bind IsSecondaryWorkspacePanelActive, Mode=OneWay}" />
                                                </VisualState.StateTriggers>
                                                <VisualState.Setters>
                                                    <Setter Target="SecondaryPaneSearchTextBox.Background" Value="{ThemeResource ActivePaneInputBackgroundBrush}" />
                                                    <Setter Target="SecondaryPaneSearchTextBox.BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                                    <Setter Target="SecondaryPaneSearchTextBox.Foreground" Value="{ThemeResource ActivePaneForegroundBrush}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <TextBox
                                        x:Name="SecondaryPaneSearchTextBox"
                                        Height="{x:Bind ShellControlSize, Mode=OneWay}"
                                        Style="{StaticResource PaneSearchTextBoxStyle}"
                                        PlaceholderText="{x:Bind SecondaryPaneSearchPlaceholderText, Mode=OneWay}"
                                        Text="{x:Bind SecondaryPaneSearchText, Mode=TwoWay}"
                                        GotFocus="SecondaryPaneInput_GotFocus"
                                        PointerPressed="SecondaryPaneInput_PointerPressed"
                                        TextChanged="SecondaryPaneSearchTextBox_TextChanged"
                                        KeyDown="SecondaryPaneSearchTextBox_KeyDown" />
                                </Grid>
                    </controls:ExplorerPaneNavigationBar.SearchContent>
                </controls:ExplorerPaneNavigationBar>
            </Grid>
        </Grid>

        <!-- Explorer workspace host: content panes + center action rail + status bar. -->
        <Grid
            x:Name="ExplorerShellGrid"
            Grid.Row="2"
            RowDefinitions="*,Auto"
            Padding="0"
            Visibility="{x:Bind ExplorerShellVisibility, Mode=OneWay}">
            <Grid
                x:Name="ExplorerWorkspaceHost"
                Grid.Row="0"
                Padding="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="PrimaryPaneColumn" Width="{x:Bind ExplorerPanePrimaryColumnWidth, Mode=OneWay}" />
                    <ColumnDefinition x:Name="ExplorerPaneActionRailColumn" Width="{x:Bind ExplorerPaneActionRailColumnWidth, Mode=OneWay}" />
                    <ColumnDefinition x:Name="SecondaryPaneColumn" Width="{x:Bind ExplorerPaneSecondaryColumnWidth, Mode=OneWay}" />
                </Grid.ColumnDefinitions>

                <Grid
                    x:Name="PrimaryPaneHost"
                    Grid.Column="0"
                    PointerPressed="PrimaryPaneSurface_PointerPressed"
                    RowDefinitions="*,Auto"
                    Padding="0">
                    <Grid
                        x:Name="ExplorerBodyGrid"
                        Grid.Row="0"
                        Padding="0">
                        <Grid x:Name="ExplorerBodyShadowReceiverGrid" />
                        <Border
                            x:Name="ExplorerBodyBorder"
                            Padding="0"
                            Background="{x:Bind PrimaryPaneBodyBackground, Mode=OneWay}"
                            BorderBrush="{x:Bind PrimaryPaneBodyBorderBrush, Mode=OneWay}"
                            BorderThickness="{x:Bind PrimaryPaneBodyBorderThickness, Mode=OneWay}"
                            CornerRadius="{ThemeResource OverlayCornerRadius}"
                            Loaded="ExplorerBodyBorder_Loaded"
                            Translation="{x:Bind PrimaryPaneBodyTranslation, Mode=OneWay}">
                            <Border.Shadow>
                                <ThemeShadow x:Name="ExplorerBodyThemeShadow" />
                            </Border.Shadow>
                            <Grid RowDefinitions="Auto,*">
                        <Border
                            x:Name="DetailsHeaderBorder"
                            Width="{x:Bind DetailsRowWidth, Mode=OneWay}"
                            Margin="10,0,0,4"
                            Padding="0"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            Visibility="{x:Bind DetailsHeaderVisibility, Mode=OneWay}">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="DetailsHeaderTranslateTransform" />
                            </Border.RenderTransform>
                            <Grid x:Name="DetailsHeaderGrid" Height="28" Margin="0" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=NameColumnWidth}" MinWidth="120" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=TypeColumnWidth}" MinWidth="90" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=SizeColumnWidth}" MinWidth="80" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=ModifiedColumnWidth}" MinWidth="120" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    x:Name="NameHeaderBorder"
                                    Style="{StaticResource DetailsHeaderHitTargetStyle}"
                                    PointerEntered="DetailsHeader_PointerEntered"
                                    PointerExited="DetailsHeader_PointerExited"
                                    PointerPressed="DetailsHeader_PointerPressed"
                                    Tag="Name">
                                    <Grid Margin="{Binding ElementName=RootWindow, Path=NameHeaderMargin}" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            x:Name="NameHeaderTextBlock"
                                            x:Uid="NameHeaderTextBlock"
                                            Style="{StaticResource DetailsHeaderTextStyle}" />
                                        <TextBlock
                                            x:Name="NameHeaderSortGlyphTextBlock"
                                            Grid.Column="2"
                                            Style="{StaticResource DetailsHeaderSortGlyphStyle}" />
                                    </Grid>
                                </Border>
                                <Border
                                    x:Name="TypeHeaderBorder"
                                    Grid.Column="2"
                                    Style="{StaticResource DetailsHeaderHitTargetStyle}"
                                    PointerEntered="DetailsHeader_PointerEntered"
                                    PointerExited="DetailsHeader_PointerExited"
                                    PointerPressed="DetailsHeader_PointerPressed"
                                    Tag="Type">
                                    <Grid Margin="14,0,0,0" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            x:Name="TypeHeaderTextBlock"
                                            x:Uid="TypeHeaderTextBlock"
                                            Style="{StaticResource DetailsHeaderTextStyle}" />
                                        <TextBlock
                                            x:Name="TypeHeaderSortGlyphTextBlock"
                                            Grid.Column="2"
                                            Style="{StaticResource DetailsHeaderSortGlyphStyle}" />
                                    </Grid>
                                </Border>
                                <Border
                                    x:Name="SizeHeaderBorder"
                                    Grid.Column="4"
                                    Style="{StaticResource DetailsHeaderHitTargetStyle}"
                                    PointerEntered="DetailsHeader_PointerEntered"
                                    PointerExited="DetailsHeader_PointerExited"
                                    PointerPressed="DetailsHeader_PointerPressed"
                                    Tag="Size">
                                    <Grid Margin="14,0,0,0" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            x:Name="SizeHeaderTextBlock"
                                            x:Uid="SizeHeaderTextBlock"
                                            Style="{StaticResource DetailsHeaderTextStyle}" />
                                        <TextBlock
                                            x:Name="SizeHeaderSortGlyphTextBlock"
                                            Grid.Column="2"
                                            Style="{StaticResource DetailsHeaderSortGlyphStyle}" />
                                    </Grid>
                                </Border>
                                <Border
                                    x:Name="ModifiedHeaderBorder"
                                    Grid.Column="6"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource DetailsHeaderHitTargetStyle}"
                                    PointerEntered="DetailsHeader_PointerEntered"
                                    PointerExited="DetailsHeader_PointerExited"
                                    PointerPressed="DetailsHeader_PointerPressed"
                                    Tag="ModifiedDate">
                                    <Grid Margin="14,0,0,0" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            x:Name="ModifiedHeaderTextBlock"
                                            x:Uid="ModifiedHeaderTextBlock"
                                            Style="{StaticResource DetailsHeaderTextStyle}" />
                                        <TextBlock
                                            x:Name="ModifiedHeaderSortGlyphTextBlock"
                                            Grid.Column="2"
                                            Style="{StaticResource DetailsHeaderSortGlyphStyle}" />
                                    </Grid>
                                </Border>

                                <local:ColumnSplitter
                                    x:Name="HeaderSplitter1"
                                    Grid.Column="1"
                                    GuideBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    Tag="1"
                                    PointerEntered="ColumnSplitterHover_PointerEntered"
                                    PointerExited="ColumnSplitterHover_PointerExited" />
                                <local:ColumnSplitter
                                    x:Name="HeaderSplitter2"
                                    Grid.Column="3"
                                    GuideBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    Tag="2"
                                    PointerEntered="ColumnSplitterHover_PointerEntered"
                                    PointerExited="ColumnSplitterHover_PointerExited" />
                                <local:ColumnSplitter
                                    x:Name="HeaderSplitter3"
                                    Grid.Column="5"
                                    GuideBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    Tag="3"
                                    PointerEntered="ColumnSplitterHover_PointerEntered"
                                    PointerExited="ColumnSplitterHover_PointerExited" />
                                <local:ColumnSplitter
                                    x:Name="HeaderSplitter4"
                                    Grid.ColumnSpan="7"
                                    HorizontalAlignment="Right"
                                    GuideBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    Tag="4"
                                    PointerEntered="ColumnSplitterHover_PointerEntered"
                                    PointerExited="ColumnSplitterHover_PointerExited" />
                            </Grid>
                        </Border>

                        <ScrollViewer
                            x:Name="DetailsEntriesScrollViewer"
                            Grid.Row="1"
                            Style="{StaticResource EntryListScrollViewerStyle}"
                            HorizontalScrollBarVisibility="{x:Bind EntriesHorizontalScrollBarVisibility, Mode=OneWay}"
                            HorizontalScrollMode="{x:Bind EntriesHorizontalScrollMode, Mode=OneWay}"
                            VerticalScrollBarVisibility="Visible"
                            VerticalScrollMode="Enabled"
                            DoubleTapped="GroupedEntriesView_DoubleTapped"
                            PointerPressed="GroupedEntriesView_PointerPressedPreview"
                            RightTapped="GroupedEntriesView_RightTapped"
                            Visibility="{x:Bind DetailsItemsVisibility, Mode=OneWay}">
                            <ItemsRepeater x:Name="DetailsEntriesRepeater" ItemsSource="{x:Bind PrimaryEntries, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Grid RowDefinitions="Auto,Auto">
                                            <Border
                                                Grid.Row="0"
                                                Height="{Binding ElementName=RootWindow, Path=EntryItemMetrics.GroupHeaderHeight}"
                                                Margin="{Binding DetailsGroupHeaderMargin}"
                                                Padding="8,0,8,0"
                                                HorizontalAlignment="Stretch"
                                                Visibility="{Binding HeaderRowVisibility}">
                                                <Border Background="Transparent" PointerPressed="GroupHeaderBorder_PointerPressed">
                                                    <Grid HorizontalAlignment="Stretch">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=NameColumnWidth}" MinWidth="120" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=TypeColumnWidth}" MinWidth="90" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=SizeColumnWidth}" MinWidth="80" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=ModifiedColumnWidth}" MinWidth="120" />
                                                        </Grid.ColumnDefinitions>

                                                        <controls:EntryGroupHeader
                                                            Grid.Column="0"
                                                            ContentPadding="6,0,0,0"
                                                            CountText="{Binding GroupCountText}"
                                                            ExpandGlyph="{Binding GroupExpandGlyph}"
                                                            HeaderText="{Binding GroupHeaderText}"
                                                            Metrics="{Binding ElementName=RootWindow, Path=EntryItemMetrics}"
                                                            ShowBottomBorder="False"
                                                            ShowExpandGlyph="True" />
                                                    </Grid>
                                                </Border>
                                            </Border>
                                            <controls:EntryItemHost
                                                Grid.Row="1"
                                                Style="{StaticResource DetailsEntryItemHostStyle}"
                                                Width="{Binding ElementName=RootWindow, Path=DetailsRowWidth}"
                                                MinHeight="{Binding ElementName=RootWindow, Path=EntryItemMetrics.RowHeight}"
                                                IsSelected="{Binding IsExplicitlySelected, Mode=OneWay}"
                                                IsAnchorFocused="{Binding IsKeyboardAnchor, Mode=OneWay}"
                                                PointerPressed="EntryRow_PointerPressed"
                                                SelectedBackground="{Binding RowBackground}"
                                                SelectedPointerOverBackground="{Binding RowBackground}"
                                                SelectedPressedBackground="{Binding RowBackground}"
                                                Visibility="{Binding DetailsRowVisibility}">
                                                <Grid Margin="6,0,0,0" HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=NameColumnWidth}" MinWidth="120" />
                                                        <ColumnDefinition Width="6" />
                                                        <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=TypeColumnWidth}" MinWidth="90" />
                                                        <ColumnDefinition Width="6" />
                                                        <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=SizeColumnWidth}" MinWidth="80" />
                                                        <ColumnDefinition Width="6" />
                                                        <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=ModifiedColumnWidth}" MinWidth="120" />
                                                    </Grid.ColumnDefinitions>
                                                    <controls:EntryNameCell
                                                        Grid.Column="0"
                                                        ContentMargin="{Binding ElementName=RootWindow, Path=DetailsNameCellMargin}"
                                                        Entry="{Binding}"
                                                        Metrics="{Binding ElementName=RootWindow, Path=EntryItemMetrics}"
                                                        VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Style="{StaticResource DetailsCellTextStyle}" Text="{Binding Type}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="4" Style="{StaticResource DetailsCellTextStyle}" Text="{Binding SizeText}" />
                                                    <TextBlock Grid.Column="6" Style="{StaticResource DetailsCellTextStyle}" Text="{Binding ModifiedText}" />
                                                </Grid>
                                            </controls:EntryItemHost>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>

                        <ScrollViewer
                            x:Name="GroupedEntriesScrollViewer"
                            Grid.Row="1"
                            Style="{StaticResource EntryListScrollViewerStyle}"
                            HorizontalScrollBarVisibility="Auto"
                            HorizontalScrollMode="Enabled"
                            SizeChanged="GroupedEntriesScrollViewer_SizeChanged"
                            VerticalScrollBarVisibility="Hidden"
                            VerticalScrollMode="Disabled"
                            DoubleTapped="GroupedEntriesView_DoubleTapped"
                            PointerPressed="GroupedEntriesView_PointerPressedPreview"
                            RightTapped="GroupedEntriesView_RightTapped"
                            Visibility="{x:Bind GroupedColumnsVisibility, Mode=OneWay}">
                            <ItemsRepeater x:Name="GroupedEntriesRepeater" ItemsSource="{x:Bind PrimaryEntries, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Border
                                                Background="Transparent"
                                                DoubleTapped="GroupedListHeader_DoubleTapped"
                                                PointerPressed="GroupedListHeader_PointerPressed"
                                                RightTapped="GroupedListHeader_RightTapped"
                                                Visibility="{Binding HeaderRowVisibility}">
                                                <controls:EntryGroupHeader
                                                    ContentPadding="12,0,6,0"
                                                    CountText="{Binding GroupCountText}"
                                                    HeaderOpacity="0.72"
                                                    HeaderText="{Binding GroupHeaderText}"
                                                    Metrics="{Binding ElementName=RootWindow, Path=EntryItemMetrics}"
                                                    ShowExpandGlyph="False" />
                                            </Border>
                                            <controls:EntryItemHost
                                                Style="{StaticResource GroupedEntryItemHostStyle}"
                                                MinHeight="{Binding ElementName=RootWindow, Path=EntryItemMetrics.RowHeight}"
                                                IsSelected="{Binding IsExplicitlySelected, Mode=OneWay}"
                                                IsAnchorFocused="{Binding IsKeyboardAnchor, Mode=OneWay}"
                                                PointerPressed="EntryRow_PointerPressed"
                                                SelectedBackground="{Binding RowBackground}"
                                                SelectedPointerOverBackground="{Binding RowBackground}"
                                                SelectedPressedBackground="{Binding RowBackground}"
                                                Visibility="{Binding ListRowVisibility}">
                                                <controls:EntryNameCell
                                                    ContentMargin="12,0,0,0"
                                                    Entry="{Binding}"
                                                    Metrics="{Binding ElementName=RootWindow, Path=EntryItemMetrics}" />
                                            </controls:EntryItemHost>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>

                        <Grid Grid.Row="1" Visibility="Collapsed">
                            <Grid.Resources>
                                <Style BasedOn="{StaticResource ContextMenuFlyoutItemStyle}" TargetType="MenuFlyoutItem" />
                                <Style BasedOn="{StaticResource ContextMenuFlyoutSubItemStyle}" TargetType="MenuFlyoutSubItem" />
                                <Style x:Key="ContextMenuNoIconItemStyle" BasedOn="{StaticResource ContextMenuFlyoutItemStyle}" TargetType="MenuFlyoutItem">
                                    <Setter Property="Padding" Value="0,0,24,0" />
                                </Style>
                                <controls:CommandMenuFlyout
                                    x:Name="FileEntriesContextFlyout"
                                    MenuFlyoutPresenterStyle="{StaticResource CommandMenuFlyoutPresenterStyle}"
                                    Opening="StaticEntriesContextFlyout_Opening"
                                    Closed="StaticEntriesContextFlyout_Closed">
                                    <controls:CommandMenuFlyout.Commands>
                                        <controls:CommandMenuFlyoutItem CommandId="cut" Label="{Binding Source={StaticResource Strings}, Path=[CommonCut]}"><controls:CommandMenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C6;" /></controls:CommandMenuFlyoutItem.Icon></controls:CommandMenuFlyoutItem>
                                        <controls:CommandMenuFlyoutItem CommandId="copy" Label="{Binding Source={StaticResource Strings}, Path=[CommonCopy]}"><controls:CommandMenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" /></controls:CommandMenuFlyoutItem.Icon></controls:CommandMenuFlyoutItem>
                                        <controls:CommandMenuFlyoutItem CommandId="rename" Label="{Binding Source={StaticResource Strings}, Path=[CommonRename]}"><controls:CommandMenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8AC;" /></controls:CommandMenuFlyoutItem.Icon></controls:CommandMenuFlyoutItem>
                                        <controls:CommandMenuFlyoutItem CommandId="delete" Label="{Binding Source={StaticResource Strings}, Path=[CommonDelete]}"><controls:CommandMenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" /></controls:CommandMenuFlyoutItem.Icon></controls:CommandMenuFlyoutItem>
                                    </controls:CommandMenuFlyout.Commands>
                                    <MenuFlyoutItem Click="EntriesContextMenuItem_Click" Tag="open" Text="{Binding Source={StaticResource Strings}, Path=[CommonOpen]}"><MenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8E5;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                    <MenuFlyoutItem Click="EntriesContextMenuItem_Click" Tag="open-with" Text="{Binding Source={StaticResource Strings}, Path=[CommonOpenWith]}"><MenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7AC;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                    <MenuFlyoutItem Click="EntriesContextMenuItem_Click" Tag="open-target" Text="{Binding Source={StaticResource Strings}, Path=[CommonOpenTarget]}"><MenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE838;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                    <MenuFlyoutItem Click="EntriesContextMenuItem_Click" Tag="run-as-administrator" Text="{Binding Source={StaticResource Strings}, Path=[CommonRunAsAdministrator]}"><MenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7EF;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                    <MenuFlyoutItem Click="EntriesContextMenuItem_Click" Tag="share" Text="{Binding Source={StaticResource Strings}, Path=[CommonShare]}"><MenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72D;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                    <MenuFlyoutSubItem x:Name="FileArchiveActionsSubMenu" Style="{StaticResource ContextMenuFlyoutSubItemStyle}" Text="{Binding Source={StaticResource Strings}, Path=[CommonArchiveActions]}">
                                        <MenuFlyoutSubItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7B8;" /></MenuFlyoutSubItem.Icon>
                                        <MenuFlyoutItem x:Name="FileExtractSmartMenuItem" Click="EntriesContextMenuItem_Click" Tag="extract-smart" Text="{Binding Source={StaticResource Strings}, Path=[CommonExtractSmart]}" />
                                        <MenuFlyoutItem x:Name="FileExtractHereMenuItem" Click="EntriesContextMenuItem_Click" Tag="extract-here" Text="{Binding Source={StaticResource Strings}, Path=[CommonExtractHere]}" />
                                        <MenuFlyoutItem x:Name="FileExtractToFolderMenuItem" Click="EntriesContextMenuItem_Click" Tag="extract-to-folder" Text="" />
                                        <MenuFlyoutSeparator x:Name="FileArchiveExtractSeparator" />
                                        <MenuFlyoutItem x:Name="FileCompressZipMenuItem" Click="EntriesContextMenuItem_Click" Tag="compress-zip" Text="{Binding Source={StaticResource Strings}, Path=[CommonCompressZipAction]}" />
                                    </MenuFlyoutSubItem>
                                    <MenuFlyoutItem Click="EntriesContextMenuItem_Click" Tag="create-shortcut" Text="{Binding Source={StaticResource Strings}, Path=[CommonCreateShortcut]}"><MenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE71B;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                    <MenuFlyoutItem Click="EntriesContextMenuItem_Click" Tag="copy-path" Text="{Binding Source={StaticResource Strings}, Path=[CommonCopyFilePath]}"><MenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                    <MenuFlyoutItem IsEnabled="False" Text="{Binding Source={StaticResource Strings}, Path=[CommonSetTag]}"><MenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8EC;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                    <MenuFlyoutItem Click="EntriesContextMenuItem_Click" Tag="properties" Text="{Binding Source={StaticResource Strings}, Path=[CommonProperties]}"><MenuFlyoutItem.Icon><FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE946;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                </controls:CommandMenuFlyout>

                                <controls:CommandMenuFlyout
                                    x:Name="FolderEntriesContextFlyout"
                                    MenuFlyoutPresenterStyle="{StaticResource CommandMenuFlyoutPresenterStyle}"
                                    Opening="StaticEntriesContextFlyout_Opening"
