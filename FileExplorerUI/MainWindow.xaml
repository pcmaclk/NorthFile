<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FileExplorerUI.MainWindow"
    x:Name="RootWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileExplorerUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FileExplorerUI">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8" Padding="8">
        <Grid
            ColumnDefinitions="Auto,Auto,Auto,Auto,4*,1*"
            Height="36"
            ColumnSpacing="8">
            <Button
                x:Name="BackButton"
                Style="{StaticResource SubtleButtonStyle}"
                Width="32"
                Height="32"
                Padding="0"
                Click="BackButton_Click"
                ToolTipService.ToolTip="Back">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE72B;" />
            </Button>
            <Button
                x:Name="ForwardButton"
                Grid.Column="1"
                Style="{StaticResource SubtleButtonStyle}"
                Width="32"
                Height="32"
                Padding="0"
                Click="ForwardButton_Click"
                ToolTipService.ToolTip="Forward">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE72A;" />
            </Button>
            <Button
                x:Name="UpButton"
                Grid.Column="2"
                Style="{StaticResource SubtleButtonStyle}"
                Width="32"
                Height="32"
                Padding="0"
                Click="UpButton_Click"
                ToolTipService.ToolTip="Up">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE74A;" />
            </Button>
            <Button
                x:Name="LoadButton"
                Grid.Column="3"
                Style="{StaticResource SubtleButtonStyle}"
                Width="32"
                Height="32"
                Padding="0"
                Click="LoadButton_Click"
                ToolTipService.ToolTip="Go">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Glyph="&#xE72C;" />
            </Button>
            <Grid Grid.Column="4">
                <Border
                    x:Name="AddressBreadcrumbBorder"
                    Height="32"
                    Padding="6,0,72,0"
                    Background="#FFFBFBFB"
                    BorderBrush="{ThemeResource TextControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    SizeChanged="AddressBreadcrumbBorder_SizeChanged"
                    Tapped="AddressBreadcrumbBorder_Tapped">
                    <Grid
                        ColumnDefinitions="Auto,*"
                        VerticalAlignment="Center">
                        <Button
                            x:Name="OverflowBreadcrumbButton"
                            Grid.Column="0"
                            Style="{StaticResource SubtleButtonStyle}"
                            Padding="6, 0, 6, 1"
                            Margin="0,0,4,0"
                            Visibility="Collapsed"
                            Click="OverflowBreadcrumbButton_Click"
                            ToolTipService.ToolTip="Show hidden path parts">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="12"
                                Glyph="&#xE712;" />
                        </Button>
                        <ItemsControl
                            Grid.Column="1"
                            x:Name="BreadcrumbMeasureItemsControl"
                            Opacity="0"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding Breadcrumbs, ElementName=RootWindow}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:BreadcrumbItemViewModel">
                                    <Grid
                                        ColumnDefinitions="Auto,Auto"
                                        Loaded="MeasureBreadcrumbItem_Loaded"
                                        SizeChanged="MeasureBreadcrumbItem_SizeChanged">
                                        <Button
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="10, 0, 10, 1"
                                            IsHitTestVisible="False">
                                            <TextBlock
                                                Text="{Binding Label}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Button>
                                        <Button
                                            Grid.Column="1"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="4, 4, 4, 4"
                                            Visibility="{Binding ChevronVisibility}"
                                            IsHitTestVisible="False">
                                            <Button.Content>
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="12"
                                                    Glyph="&#xE76C;" />
                                            </Button.Content>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl
                            Grid.Column="1"
                            x:Name="BreadcrumbItemsControl"
                            Opacity="0"
                            ItemsSource="{Binding VisibleBreadcrumbs, ElementName=RootWindow}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:BreadcrumbItemViewModel">
                                    <Grid ColumnDefinitions="Auto,Auto">
                                        <Button
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="10, 0, 10, 1"
                                            Click="BreadcrumbButton_Click"
                                            Tag="{Binding FullPath}">
                                            <TextBlock
                                                Text="{Binding Label}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Button>
                                        <Button
                                            Grid.Column="1"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="4, 4, 4, 4"
                                            Visibility="{Binding ChevronVisibility}"
                                            Click="BreadcrumbChevronButton_Click"
                                            Tag="{Binding FullPath}">
                                            <Button.Content>
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="12"
                                                    Glyph="&#xE76C;" />
                                            </Button.Content>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <TextBox
                    x:Name="PathTextBox"
                    PlaceholderText="Address"
                    Visibility="Collapsed"
                    KeyDown="PathTextBox_KeyDown"
                    LostFocus="PathTextBox_LostFocus"
                    Padding="12, 7, 36, 8"
                    Text="C:\" />
            </Grid>
            <TextBox
                x:Name="SearchTextBox"
                Grid.Column="5"
                Height="32"
                PlaceholderText="Search in current folder"
                KeyDown="SearchTextBox_KeyDown" />
        </Grid>

        <Grid
            x:Name="ExplorerBodyGrid"
            Grid.Row="1"
            ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{x:Bind SidebarColumnWidth, Mode=OneWay}" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ScrollViewer
                x:Name="SidebarScrollViewer"
                Grid.Column="0"
                Padding="0,4,0,0"
                HorizontalContentAlignment="Stretch"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel
                    x:Name="SidebarGroupsHost"
                    HorizontalAlignment="Stretch"
                    Spacing="4"
                    Margin="0"
                    BorderThickness="0"/>
            </ScrollViewer>

            <Grid Grid.Column="2" Padding="8,0,0,0">
                <Border
                    CornerRadius="10"
                    Background="#FFFFFFFF"
                    BorderBrush="#FFDADDE3"
                    BorderThickness="1"
                    Padding="8, 8, 0, 8"
                    >
                    <Grid RowDefinitions="Auto,*">
                        <Border x:Name="DetailsHeaderBorder" BorderBrush="#FFE3E5E8" BorderThickness="0" Margin="0" Padding="8,0,8,0" HorizontalAlignment="Left" Background="Transparent" Width="{x:Bind DetailsRowWidth, Mode=OneWay}">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="DetailsHeaderTranslateTransform" />
                            </Border.RenderTransform>
                            <Border BorderBrush="#FFE3E5E8" BorderThickness="0,0,0,1">
                                <Grid
                                    x:Name="DetailsHeaderGrid"
                                    Margin="0"
                                    Height="28"
                                    HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=NameColumnWidth}" MinWidth="120" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=TypeColumnWidth}" MinWidth="90" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=SizeColumnWidth}" MinWidth="80" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=ModifiedColumnWidth}" MinWidth="120" />
                                    <ColumnDefinition Width="6" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Padding="32,0,0,0" Background="Transparent">
                                    <TextBlock
                                        Text="名称"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        FontSize="12"
                                        Foreground="#FF6F6F6F" />
                                </Border>
                                <TextBlock
                                    Grid.Column="2"
                                    Text="类型"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    FontSize="12"
                                    Foreground="#FF6F6F6F" />
                                <TextBlock
                                    Grid.Column="4"
                                    Text="大小"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    FontSize="12"
                                    Foreground="#FF6F6F6F" />
                                <TextBlock
                                    Grid.Column="6"
                                    Text="修改日期"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    FontSize="12"
                                    Foreground="#FF6F6F6F" />

                                <local:ColumnSplitter
                                    x:Name="HeaderSplitter1"
                                    Grid.Column="1"
                                    Tag="1"
                                    PointerEntered="ColumnSplitterHover_PointerEntered"
                                    PointerExited="ColumnSplitterHover_PointerExited" />
                                <local:ColumnSplitter
                                    x:Name="HeaderSplitter2"
                                    Grid.Column="3"
                                    Tag="2"
                                    PointerEntered="ColumnSplitterHover_PointerEntered"
                                    PointerExited="ColumnSplitterHover_PointerExited" />
                                <local:ColumnSplitter
                                    x:Name="HeaderSplitter3"
                                    Grid.Column="5"
                                    Tag="3"
                                    PointerEntered="ColumnSplitterHover_PointerEntered"
                                    PointerExited="ColumnSplitterHover_PointerExited" />
                                <local:ColumnSplitter
                                    x:Name="HeaderSplitter4"
                                    Grid.Column="7"
                                    Tag="4"
                                    PointerEntered="ColumnSplitterHover_PointerEntered"
                                    PointerExited="ColumnSplitterHover_PointerExited" />


                                </Grid>
                            </Border>
                        </Border>

                        <ListView
                            x:Name="EntriesListView"
                            Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            Margin="0,8,0,0"
                            IsItemClickEnabled="False"
                            SelectionMode="Single"
                            Background="Transparent"
                            Padding="0"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollMode="Enabled"
                            ScrollViewer.VerticalScrollBarVisibility="Visible"
                            ScrollViewer.VerticalScrollMode="Enabled"
                            DoubleTapped="EntriesListView_DoubleTapped"
                            ContextRequested="EntriesListView_ContextRequested"
                            Loaded="EntriesListView_Loaded">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                    <Setter Property="Width" Value="{Binding ElementName=RootWindow, Path=DetailsRowWidth}" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Height" Value="30" />
                                    <Setter Property="MinHeight" Value="30" />
                                    <Setter Property="CornerRadius" Value="0" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ContextFlyout>
                                <MenuFlyout
                                    x:Name="EntriesContextFlyout"
                                    Opening="EntriesContextFlyout_Opening"
                                    Closed="EntriesContextFlyout_Closed">
                                    <MenuFlyoutItem
                                        Click="ContextRename_Click"
                                        Text="Rename" />
                                    <MenuFlyoutItem
                                        Click="ContextDelete_Click"
                                        Text="Delete" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem
                                        Click="ContextRefresh_Click"
                                        Text="Refresh" />
                                </MenuFlyout>
                            </ListView.ContextFlyout>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Height="30"
                                        Padding="8,0,8,0"
                                        HorizontalAlignment="Stretch"
                                        RightTapped="EntryRow_RightTapped">
                                        <Grid HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=NameColumnWidth}" MinWidth="120" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=TypeColumnWidth}" MinWidth="90" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=SizeColumnWidth}" MinWidth="80" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="{Binding ElementName=RootWindow, Path=ModifiedColumnWidth}" MinWidth="120" />
                                                <ColumnDefinition Width="6" />
                                            </Grid.ColumnDefinitions>

                                            <Grid
                                                Grid.Column="0"
                                                ColumnDefinitions="18,8,*"
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Width="18"
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="14"
                                                    Foreground="{Binding IconForeground}"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding IconGlyph}" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    Margin="0,0,4,0"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding Name}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                            <TextBlock
                                                Grid.Column="2"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Type}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding SizeText}" />
                                            <TextBlock
                                                Grid.Column="6"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding ModifiedText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border
                    x:Name="CommandDockPanel"
                    Width="360"
                    Padding="10"
                    BorderThickness="1"
                    CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="10"
                    PointerExited="CommandDockPanel_PointerExited">
                    <StackPanel Spacing="8">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="Command Dock" />
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Button
                                x:Name="RenameButton"
                                Grid.Column="0"
                                Click="RenameButton_Click"
                                Content="Rename" />
                            <Button
                                x:Name="DeleteButton"
                                Grid.Column="1"
                                Click="DeleteButton_Click"
                                Content="Delete" />
                            <Button
                                x:Name="NextButton"
                                Grid.Column="2"
                                Click="NextButton_Click"
                                Content="Load More" />
                        </Grid>
                        <TextBox
                            x:Name="RenameTextBox"
                            PlaceholderText="new name" />
                        <CheckBox
                            x:Name="RecursiveDeleteCheckBox"
                            Content="Recursive delete" />

                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8">
                            <RadioButton
                                GroupName="DockSide"
                                Tag="Top"
                                Checked="DockRadio_Checked"
                                IsChecked="True"
                                Content="Top" />
                            <RadioButton
                                Grid.Column="1"
                                GroupName="DockSide"
                                Tag="Right"
                                Checked="DockRadio_Checked"
                                Content="Right" />
                            <RadioButton
                                Grid.Column="2"
                                GroupName="DockSide"
                                Tag="Bottom"
                                Checked="DockRadio_Checked"
                                Content="Bottom" />
                            <ToggleSwitch
                                x:Name="CommandAutoHideSwitch"
                                Grid.Column="3"
                                HorizontalAlignment="Right"
                                Toggled="CommandAutoHideSwitch_Toggled"
                                Header="Auto hide" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Button
                    x:Name="CommandPeekButton"
                    Visibility="Collapsed"
                    Content="Commands"
                    Click="CommandPeekButton_Click"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="10" />
            </Grid>

            <local:ColumnSplitter
                x:Name="SidebarSplitter"
                Grid.Column="2"
                Width="8"
                Margin="4,0,0,0"
                HorizontalAlignment="Left"
                ShowGuide="False"
                PointerEntered="ColumnSplitterHover_PointerEntered"
                PointerExited="ColumnSplitterHover_PointerExited" />
        </Grid>

        <TextBlock
            x:Name="StatusTextBlock"
            Grid.Row="2"
            TextWrapping="Wrap"
            Text="Loading..." />
    </Grid>
</Window>
