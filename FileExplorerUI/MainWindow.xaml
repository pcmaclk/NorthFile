                        <Canvas x:Name="RenameOverlayCanvas" Grid.Row="1" Margin="0,8,0,0">
                            <Border
                                x:Name="RenameOverlayBorder"
                                Width="160"
                                Height="24"
                                Background="White"
                                BorderBrush="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                                BorderThickness="1"
                                Padding="1,0,8,1"
                                CornerRadius="0"
                                Visibility="Collapsed">
                                <TextBox
                                    x:Name="RenameOverlayTextBox"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    FontSize="14"
                                    FocusVisualPrimaryThickness="0"
                                    FocusVisualSecondaryThickness="0"
                                    HorizontalContentAlignment="Left"
                                    KeyDown="RenameOverlayTextBox_KeyDown"
                                    LostFocus="RenameOverlayTextBox_LostFocus"
                                    MinHeight="24"
                                    Padding="0"
                                    TextAlignment="Left"
                                    Margin="0,-2,0,0"
                                    UseSystemFocusVisuals="False"
                                    VerticalContentAlignment="Center">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="TextBox">
                                            <Grid>
                                                <Border
                                                    x:Name="BorderElement"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    Control.IsTemplateFocusTarget="True" />
                                                <ScrollViewer
                                                    x:Name="ContentElement"
                                                    AutomationProperties.AccessibilityView="Raw"
                                                    Foreground="{TemplateBinding Foreground}"
                                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                    HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                    HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                                    IsDeferredScrollingEnabled="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                                                    IsHorizontalRailEnabled="{TemplateBinding ScrollViewer.IsHorizontalRailEnabled}"
                                                    IsTabStop="False"
                                                    IsVerticalRailEnabled="{TemplateBinding ScrollViewer.IsVerticalRailEnabled}"
                                                    Margin="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}"
                                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                    VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                                    VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                                    ZoomMode="Disabled" />
                                            </Grid>
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>
                            </Border>
                        </Canvas>
                    </Grid>
                </Border>

                <Border
                    x:Name="CommandDockPanel"
                    Width="360"
                    Margin="10"
                    Padding="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    PointerExited="CommandDockPanel_PointerExited"
                    Visibility="Collapsed">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="CommandDockTitleTextBlock" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Button x:Name="RenameButton" x:Uid="RenameButton" Grid.Column="0" Click="RenameButton_Click" />
                            <Button x:Name="DeleteButton" x:Uid="DeleteButton" Grid.Column="1" Click="DeleteButton_Click" />
                            <Button x:Name="NextButton" x:Uid="NextButton" Grid.Column="2" Click="NextButton_Click" />
                        </Grid>
                        <TextBox x:Name="RenameTextBox" x:Uid="RenameTextBox" />
                        <CheckBox x:Name="RecursiveDeleteCheckBox" x:Uid="RecursiveDeleteCheckBox" />

                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8">
                            <RadioButton
                                x:Uid="DockTopRadioButton"
                                GroupName="DockSide"
                                Tag="Top"
                                Checked="DockRadio_Checked"
                                IsChecked="True" />
                            <RadioButton
                                x:Uid="DockRightRadioButton"
                                Grid.Column="1"
                                GroupName="DockSide"
                                Tag="Right"
                                Checked="DockRadio_Checked" />
                            <RadioButton
                                x:Uid="DockBottomRadioButton"
                                Grid.Column="2"
                                GroupName="DockSide"
                                Tag="Bottom"
                                Checked="DockRadio_Checked" />
                            <ToggleSwitch
                                x:Name="CommandAutoHideSwitch"
                                x:Uid="CommandAutoHideSwitch"
                                Grid.Column="3"
                                HorizontalAlignment="Right"
                                Toggled="CommandAutoHideSwitch_Toggled" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Button
                    x:Name="CommandPeekButton"
                    x:Uid="CommandPeekButton"
                    Margin="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Click="CommandPeekButton_Click"
                    Visibility="Collapsed" />
                </Grid>

                <Grid Grid.Row="1" Height="32">
                    <TextBlock
                        x:Name="StatusTextBlock"
                        x:Uid="StatusTextBlock"
                        Margin="18,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        LineHeight="11"
                        LineStackingStrategy="BlockLineHeight"
                        TextWrapping="Wrap" />
                </Grid>
            </Grid>

            <local:ColumnSplitter
                x:Name="SidebarSplitter"
                Grid.Column="1"
                Width="8"
                Margin="-4,0,0,0"
                HorizontalAlignment="Left"
                ShowGuide="False"
                VerticalAlignment="Stretch"
                PointerEntered="ColumnSplitterHover_PointerEntered"
                PointerExited="ColumnSplitterHover_PointerExited" />
        </Grid>
    </Grid>
</Window>
